                    renderModalPlanMaterias();
                });
            });

            document.querySelectorAll('.btn-cancel-modal-materia').forEach((btn) => {
                btn.addEventListener('click', () => {
                    editingModalMateriaCodes.delete(btn.dataset.codigoOriginal);
                    renderModalPlanMaterias();
                });
            });

            document.querySelectorAll('.btn-save-modal-materia').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const codigoOriginal = btn.dataset.codigoOriginal;
                    const row = btn.closest('tr');
                    const codigoNuevo = row.querySelector('.js-modal-mat-codigo')?.value?.trim()?.toUpperCase();
                    const nombre = row.querySelector('.js-modal-mat-nombre')?.value?.trim();
                    const uv = Number(row.querySelector('.js-modal-mat-uv')?.value);
                    const semestreRaw = row.querySelector('.js-modal-mat-semestre')?.value?.trim();
                    const semestre = semestreRaw === '' ? null : Number(semestreRaw);

                    if (!codigoNuevo || !nombre || !Number.isInteger(uv) || uv < 0) {
                        alert('Verifica código, nombre y UV (entero >= 0).');
                        return;
                    }
                    if (!(semestre === null || (Number.isInteger(semestre) && semestre > 0))) {
                        alert('Semestre debe ser entero positivo o vacío.');
                        return;
                    }
                    await saveModalMateriaRow(codigoOriginal, codigoNuevo, nombre, uv, semestre);
                });
            });

            document.querySelectorAll('.btn-delete-modal-materia').forEach((btn) => {
                btn.addEventListener('click', async () => {
                    const codigo = btn.dataset.codigo;
                    if (!modalPlanContext) return;
                    if (!confirm(`¿Quitar la materia ${codigo} de este plan?`)) return;
                    try {
                        const res = await fetch(`/api/catalogos/planes/${modalPlanContext.idPlan}/materias/${encodeURIComponent(codigo)}`, {
                            method: 'DELETE'
                        });
                        const data = await res.json();
                        if (!res.ok) return alert(data.error || 'No se pudo quitar la materia del plan.');

                        await verDetallePlan(
                            modalPlanContext.idPlan,
                            modalPlanContext.nombreCarrera,
                            modalPlanContext.nombrePlan,
                            modalPlanContext.anioPlan,
                            modalPlanContext.codigoCarrera,
                            modalPlanContext.idPlan
                        );
                        await loadData();
                    } catch (error) {
                        alert('Error de red al quitar materia del plan.');
                    }
                });
            });

            initActionMenus();
            populateModalMateriaSelect();
        }

        function populateModalMateriaSelect() {
            const select = document.getElementById('modalAddMateriaSelect');
            if (!select) return;

            const inPlan = new Set((modalPlanMaterias || []).map((m) => String(m.CodigoMateria || '').toUpperCase()));
            const uniqueMaterias = [];
            const seen = new Set();

            (materiasData || []).forEach((m) => {
                const code = String(m.CodigoMateria || '').toUpperCase();
                if (!code || seen.has(code) || inPlan.has(code)) return;
                seen.add(code);
                uniqueMaterias.push({
                    codigo: code,
                    nombre: m.NombreMateria || ''
                });
            });

            uniqueMaterias.sort((a, b) => a.nombre.localeCompare(b.nombre));
            select.innerHTML = '<option value="">Selecciona una materia...</option>' +
                uniqueMaterias.map((m) =>
                    `<option value="${escapeHtml(m.codigo)}">${escapeHtml(m.codigo)} - ${escapeHtml(m.nombre)}</option>`
                ).join('');
        }

        async function saveModalMateriaRow(codigoOriginal, codigoNuevo, nombre, uvs, semestre) {
            if (!modalPlanContext) return;
            try {
                const resMateria = await fetch(`/api/catalogos/materias/${encodeURIComponent(codigoOriginal)}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ codigoNuevo, nombre, uvs })
                });
                const dataMateria = await resMateria.json();
                if (!resMateria.ok) return alert(dataMateria.error || 'No se pudo actualizar materia.');

                const resSem = await fetch(`/api/catalogos/planes/${modalPlanContext.idPlan}/materias/${encodeURIComponent(codigoNuevo)}/semestre`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ semestre })
                });
                const dataSem = await resSem.json();
                if (!resSem.ok) return alert(dataSem.error || 'No se pudo actualizar semestre.');

                editingModalMateriaCodes.delete(codigoOriginal);
                editingModalMateriaCodes.delete(codigoNuevo);

                await verDetallePlan(
                    modalPlanContext.idPlan,
                    modalPlanContext.nombreCarrera,
                    modalPlanContext.nombrePlan,
                    modalPlanContext.anioPlan,
                    modalPlanContext.codigoCarrera,
                    modalPlanContext.idPlan
                );
                await loadData();
            } catch (error) {
                alert('Error de red al guardar materia del plan.');
            }
        }

