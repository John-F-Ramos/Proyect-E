    <script>
        // [Mantener TODO el JavaScript original, solo agregar las variables y funciones para paginación de carreras]
        // Estado global
        let carrerasData = [];
        let materiasData = [];
        let planesData = [];
        let usuarioActual = null;
        let usuarioPlan = null;
        const editingCarreraCodes = new Set();
        const editingCarreraPlanIds = new Set();
        const editingMateriaCodes = new Set();
        const editingPlanIds = new Set();
        const editingModalMateriaCodes = new Set();
        let modalPlanContext = null;
        let modalPlanMaterias = [];
        let pdfPreviewRows = [];
        let activeCatalogTab = 'carreras';
        let materiasLoaded = false;
        let materiasPage = 1;
        let materiasPageSize = 80;
        let materiasTotal = 0;
        let materiasTotalPages = 1;
        let materiasSearchTerm = '';
        let pensumMateriasData = [];

        // Variables para paginación de carreras
        let carrerasPage = 1;
        let carrerasPageSize = 15;
        let carrerasTotalPages = 1;
        let carrerasShowAll = false;
        let carrerasFlatList = []; // Lista plana de todos los registros (carreras + planes)

        // Función para aplanar los datos de carreras y planes
        function flattenCarrerasData() {
            const flat = [];
            if (!carrerasData || carrerasData.length === 0) return flat;
            
            carrerasData.forEach(carrera => {
                const planesCarrera = planesData.filter(p => p.CodigoCarrera === carrera.CodigoCarrera);
                
                if (planesCarrera.length === 0) {
                    flat.push({
                        type: 'carrera',
                        carrera: carrera,
                        plan: null,
                        isEditing: editingCarreraCodes.has(String(carrera.CodigoCarrera))
                    });
                } else {
                    planesCarrera.sort((a, b) => b.AnioPlan - a.AnioPlan);
                    planesCarrera.forEach(plan => {
                        flat.push({
                            type: 'plan',
                            carrera: carrera,
                            plan: plan,
                            isEditing: editingCarreraPlanIds.has(String(plan.IdPlan))
                        });
                    });
                }
            });
            return flat;
        }

        // Renderizar carreras con paginación
        function renderCarrerasWithPagination() {
            const tbody = document.getElementById('carrerasBody');
            if (!tbody) return;

            carrerasFlatList = flattenCarrerasData();
            const totalItems = carrerasFlatList.length;
            const totalPages = carrerasShowAll ? 1 : Math.ceil(totalItems / carrerasPageSize);
            carrerasTotalPages = totalPages;
            
            if (carrerasPage > totalPages && totalPages > 0) carrerasPage = totalPages;
            
            const startIdx = carrerasShowAll ? 0 : (carrerasPage - 1) * carrerasPageSize;
            const endIdx = carrerasShowAll ? totalItems : Math.min(startIdx + carrerasPageSize, totalItems);
            const pageData = carrerasFlatList.slice(startIdx, endIdx);
            
            // Actualizar UI de paginación
            document.getElementById('carrerasTotalLabel').textContent = `${totalItems} registros`;
            document.getElementById('carrerasPageInfo').textContent = carrerasShowAll ? `1 / 1` : `${carrerasPage} / ${Math.max(1, totalPages)}`;
            document.getElementById('btnPrevCarreras').disabled = carrerasShowAll || carrerasPage <= 1;
            document.getElementById('btnNextCarreras').disabled = carrerasShowAll || carrerasPage >= totalPages;
            
            // Renderizar tabla
            tbody.innerHTML = '';
            if (pageData.length === 0) {
                tbody.innerHTML = '§<td colspan="7" class="px-6 py-4 text-center">No hay carreras registradas.§</td></tr>';
                return;
            }
            
            pageData.forEach(item => {
                if (item.type === 'carrera') {
                    const carrera = item.carrera;
                    const isEditingCarrera = item.isEditing;
                    tbody.innerHTML += `
                        <tr class="bg-white hover:bg-gray-50 carrera-row" data-codigo="${carrera.CodigoCarrera}">
                            <td class="px-6 py-4 font-medium text-gray-900">${carrera.CodigoCarrera}</td>
                            <td class="px-6 py-4" colspan="2">
                                ${isEditingCarrera
                                    ? `<input type="text" class="js-carrera-nombre w-full px-2 py-1 border border-blue-300 rounded" value="${escapeHtml(carrera.NombreCarrera)}">`
                                    : `${carrera.NombreCarrera} - Sin planes registrados`}
                            </td>
                            <td class="px-6 py-4 text-center">-</td>
                            <td class="px-6 py-4 text-center">-</td>
                            <td class="px-6 py-4 text-center">-</td>
                            <td class="px-6 py-4 text-center">
                                ${isEditingCarrera
                                    ? `<button class="btn-min btn-min-success btn-save-carrera" data-codigo="${escapeHtml(carrera.CodigoCarrera)}">Guardar</button>
                                       <button class="btn-min btn-min-cancel btn-cancel-carrera ml-1" data-codigo="${escapeHtml(carrera.CodigoCarrera)}">Cancelar</button>`
                                    : `<div class="relative inline-block text-left">
                                        <button class="btn-min btn-action-gear" data-menu-id="menu-carrera-${toDomSafe(carrera.CodigoCarrera)}" title="Acciones">
                                            <i class="fas fa-cog"></i>
                                        </button>
                                        <div id="menu-carrera-${toDomSafe(carrera.CodigoCarrera)}" class="action-menu">
                                            <button class="btn-min btn-min-primary btn-edit-carrera" data-codigo="${escapeHtml(carrera.CodigoCarrera)}">Editar carrera</button>
                                            <button class="btn-min btn-min-danger btn-delete-carrera" data-codigo="${escapeHtml(carrera.CodigoCarrera)}">Eliminar carrera</button>
                                        </div>
                                    </div>`}
                            </td>
                        </tr>
                    `;
                } else {
                    const carrera = item.carrera;
                    const plan = item.plan;
                    const isEditingCarreraPlan = item.isEditing;
                    const esMiPlan = esPlanDelUsuario(plan.IdPlan);
                    const claseAdicional = esMiPlan ? 'usuario-plan' : '';
                    const nombreCarreraFila = plan.NombreCarreraPlan || carrera.NombreCarrera;
                    
                    tbody.innerHTML += `
                        <tr class="bg-white hover:bg-gray-50 carrera-row ${claseAdicional}" 
                            data-idplan="${plan.IdPlan}" 
                            data-carrera="${escapeHtml(nombreCarreraFila)}"
                            data-codigo="${carrera.CodigoCarrera}"
                            data-plan="${plan.NombrePlan}"
                            data-anio="${plan.AnioPlan}"
                            data-materias="${plan.TotalMaterias || 0}"
                            data-uvs="${plan.TotalUVS || 0}">
                            <td class="px-6 py-4 font-medium text-gray-900">${carrera.CodigoCarrera}</td>
                            <td class="px-6 py-4">
                                ${isEditingCarreraPlan
                                    ? `<input type="text" class="js-carrera-nombre w-full px-2 py-1 border border-blue-300 rounded" value="${escapeHtml(nombreCarreraFila)}">`
                                    : `${nombreCarreraFila}`}
                                ${esMiPlan ? '<span class="badge-mi-plan"><i class="fas fa-graduation-cap mr-1"></i>Mi Plan</span>' : ''}
                            </td>
                            <td class="px-6 py-4">
                                ${plan.NombrePlan}
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="badge-materias">${plan.TotalMaterias || 0}</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="badge-uv">${plan.TotalUVS || 0} UVs</span>
                            </td>
                            <td class="px-6 py-4 text-center">${plan.AnioPlan}</td>
                            <td class="px-6 py-4 text-center">
                                ${isEditingCarreraPlan
                                    ? `<button class="btn-min btn-min-success btn-save-carrera-plan" data-idplan="${plan.IdPlan}">Guardar</button>
                                       <button class="btn-min btn-min-cancel btn-cancel-carrera-plan ml-1" data-idplan="${plan.IdPlan}">Cancelar</button>`
                                    : `<div class="relative inline-block text-left">
                                        <button class="btn-min btn-action-gear" data-menu-id="menu-plan-${plan.IdPlan}" title="Acciones">
                                            <i class="fas fa-cog"></i>
                                        </button>
                                        <div id="menu-plan-${plan.IdPlan}" class="action-menu">
                                            <button class="btn-min btn-min-primary btn-edit-carrera-plan" data-idplan="${plan.IdPlan}">Editar carrera</button>
                                            <button class="btn-min btn-min-danger btn-delete-carrera" data-codigo="${escapeHtml(carrera.CodigoCarrera)}">Eliminar carrera</button>
                                            <button class="btn-min btn-min-primary btn-edit-plan" data-id="${plan.IdPlan}" data-codigo="${escapeHtml(plan.CodigoCarrera)}" data-nombre="${escapeHtml(plan.NombrePlan)}" data-anio="${plan.AnioPlan}">Editar plan</button>
                                            <button class="btn-min btn-min-danger btn-delete-plan" data-id="${plan.IdPlan}">Eliminar plan</button>
                                        </div>
                                    </div>`}
                            </td>
                        </tr>
                    `;
                }
            });
            
            // Re-attach event listeners
            attachCarrerasEventListeners();
        }

        function attachCarrerasEventListeners() {
            document.querySelectorAll('.carrera-row').forEach(row => {
                row.removeEventListener('dblclick', handleRowDoubleClick);
                row.addEventListener('dblclick', handleRowDoubleClick);
            });
            
            document.querySelectorAll('#carrerasBody .btn-edit-carrera').forEach(btn => {
                btn.removeEventListener('click', handleEditCarrera);
                btn.addEventListener('click', handleEditCarrera);
            });
            
            document.querySelectorAll('#carrerasBody .btn-cancel-carrera').forEach(btn => {
                btn.removeEventListener('click', handleCancelCarrera);
                btn.addEventListener('click', handleCancelCarrera);
            });
            
            document.querySelectorAll('#carrerasBody .btn-save-carrera').forEach(btn => {
                btn.removeEventListener('click', handleSaveCarrera);
                btn.addEventListener('click', handleSaveCarrera);
            });
            
            document.querySelectorAll('#carrerasBody .btn-edit-carrera-plan').forEach(btn => {
                btn.removeEventListener('click', handleEditCarreraPlan);
                btn.addEventListener('click', handleEditCarreraPlan);
            });
            
            document.querySelectorAll('#carrerasBody .btn-cancel-carrera-plan').forEach(btn => {
                btn.removeEventListener('click', handleCancelCarreraPlan);
                btn.addEventListener('click', handleCancelCarreraPlan);
            });
            
            document.querySelectorAll('#carrerasBody .btn-save-carrera-plan').forEach(btn => {
                btn.removeEventListener('click', handleSaveCarreraPlan);
                btn.addEventListener('click', handleSaveCarreraPlan);
            });
            
            document.querySelectorAll('#carrerasBody .btn-delete-carrera').forEach(btn => {
                btn.removeEventListener('click', handleDeleteCarrera);
                btn.addEventListener('click', handleDeleteCarrera);
            });
            
            document.querySelectorAll('#carrerasBody .btn-edit-plan').forEach(btn => {
                btn.removeEventListener('click', handleEditPlan);
                btn.addEventListener('click', handleEditPlan);
            });
            
            document.querySelectorAll('#carrerasBody .btn-delete-plan').forEach(btn => {
                btn.removeEventListener('click', handleDeletePlan);
                btn.addEventListener('click', handleDeletePlan);
            });
            
            initActionMenus();
        }
        
        function handleRowDoubleClick(e) {
            const row = e.currentTarget;
            const idPlan = row.dataset.idplan;
            if (idPlan) {
                verDetallePlan(idPlan, row.dataset.carrera, row.dataset.plan, row.dataset.anio, row.dataset.codigo, idPlan);
            }
        }
        
        function handleEditCarrera(e) { e.stopPropagation(); startEditCarreraRow(e.currentTarget.dataset.codigo); }
        function handleCancelCarrera(e) { e.stopPropagation(); cancelEditCarreraRow(e.currentTarget.dataset.codigo); }
        async function handleSaveCarrera(e) { e.stopPropagation(); const codigo = e.currentTarget.dataset.codigo; const row = e.currentTarget.closest('tr'); const nombre = row.querySelector('.js-carrera-nombre')?.value?.trim(); if (!nombre) return alert('Debes ingresar un nombre válido.'); await saveCarreraInline(codigo, nombre); }
        function handleEditCarreraPlan(e) { e.stopPropagation(); startEditCarreraPlanRow(e.currentTarget.dataset.idplan); }
        function handleCancelCarreraPlan(e) { e.stopPropagation(); cancelEditCarreraPlanRow(e.currentTarget.dataset.idplan); }
        async function handleSaveCarreraPlan(e) { e.stopPropagation(); await saveCarreraPlanInline(e.currentTarget.dataset.idplan, e.currentTarget.closest('tr')); }
        async function handleDeleteCarrera(e) { e.stopPropagation(); await deleteCarrera(e.currentTarget.dataset.codigo); }
        function handleEditPlan(e) { e.stopPropagation(); startEditPlanRow(e.currentTarget.dataset.id); }
        async function handleDeletePlan(e) { e.stopPropagation(); await deletePlan(e.currentTarget.dataset.id); }

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function toDomSafe(value) {
            return String(value ?? '').replace(/[^a-zA-Z0-9_-]/g, '_');
        }

        async function downloadTemplateAuthenticated(endpoint, fallbackFilename) {
            try {
                const response = await fetch(endpoint, { method: 'GET' });
                const contentType = response.headers.get('content-type') || '';

                if (!response.ok) {
                    let errorCode = '';
                    if (contentType.includes('application/json')) {
                        const data = await response.json();
                        errorCode = data?.error || '';
                    }

                    if (response.status === 401 || errorCode === 'UNAUTHORIZED') {
                        alert('Tu sesión no es válida. Inicia sesión nuevamente para descargar la plantilla.');
                        return;
                    }
                    if (response.status === 403 || errorCode === 'FORBIDDEN') {
                        alert('Tu perfil no tiene permisos para descargar esta plantilla.');
                        return;
                    }
                    alert('No se pudo descargar la plantilla. Inténtalo de nuevo.');
                    return;
                }

                const blob = await response.blob();
                const disposition = response.headers.get('content-disposition') || '';
                const filenameMatch = disposition.match(/filename="([^"]+)"/);
                const filename = filenameMatch ? filenameMatch[1] : fallbackFilename;
                const downloadUrl = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = downloadUrl;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(downloadUrl);
            } catch (error) {
                alert('Error de conexión con el servidor.');
            }
        }
