            try {
                const response = await fetch(`/api/catalogos/planes/${idPlan}/materias`);
                const materias = await response.json();
                modalPlanMaterias = Array.isArray(materias) ? materias : [];
                editingModalMateriaCodes.clear();

                modalPlanContext = {
                    idPlan: Number(planIdRaw || idPlan),
                    codigoCarrera: codigoCarrera,
                    nombreCarrera: nombreCarrera,
                    nombrePlan: nombrePlan,
                    anioPlan: Number(anio)
                };

                document.getElementById('modalPlanTitulo').innerHTML = `${nombreCarrera} - ${nombrePlan} (${anio})`;
                document.getElementById('modalPlanSubtitulo').innerHTML = `Plan de Estudio`;
                document.getElementById('modalEditCodigoCarrera').value = codigoCarrera || '';
