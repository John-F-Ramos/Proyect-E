        async function saveCarreraInline(codigo, nombre) {
            if (!nombre || !nombre.trim()) return alert('Debes ingresar un nombre válido.');

            try {
                const res = await fetch(`/api/catalogos/carreras/${encodeURIComponent(codigo)}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre })
                });
                const data = await res.json();
                if (!res.ok) return alert(data.error || 'No se pudo actualizar la carrera.');
                editingCarreraCodes.delete(String(codigo));
                await loadData();
            } catch (error) {
                alert('Error de red al actualizar carrera.');
            }
        }

        async function saveCarreraPlanInline(idPlan, row) {
            const idPlanValue = Number(idPlan);
            const nombreCarreraPlan = row?.querySelector('.js-carrera-nombre')?.value?.trim();
            const codigoCarrera = row?.dataset?.codigo?.trim()?.toUpperCase();
            const nombrePlan = row?.dataset?.plan?.trim();
            const anioPlan = Number(row?.dataset?.anio);

            if (!Number.isInteger(idPlanValue) || idPlanValue <= 0) {
                return alert('IdPlan inválido.');
            }
            if (!nombreCarreraPlan || !codigoCarrera || !nombrePlan || !Number.isInteger(anioPlan) || anioPlan <= 0) {
                return alert('Completa los datos de carrera y plan para guardar.');
            }

            try {
                const res = await fetch(`/api/catalogos/planes/${idPlanValue}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ codigoCarrera, nombreCarreraPlan, nombrePlan, anioPlan })
                });
                const data = await res.json();
                if (!res.ok) return alert(data.error || 'No se pudo actualizar la fila del plan.');

                editingCarreraPlanIds.delete(String(idPlanValue));
                await loadData();
            } catch (error) {
                alert('Error de red al actualizar la carrera del plan.');
            }
        }

        async function deleteCarrera(codigo) {
            if (!confirm(`¿Eliminar la carrera ${codigo}? Esta acción no se puede deshacer.`)) return;
            try {
                const res = await fetch(`/api/catalogos/carreras/${encodeURIComponent(codigo)}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (!res.ok) return alert(data.error || 'No se pudo eliminar la carrera.');
                await loadData();
            } catch (error) {
                alert('Error de red al eliminar carrera.');
            }
        }

        async function deleteMateria(codigo) {
            if (!confirm(`¿Eliminar la materia ${codigo}?`)) return;
            try {
                const res = await fetch(`/api/catalogos/materias/${encodeURIComponent(codigo)}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (!res.ok) return alert(data.error || 'No se pudo eliminar la materia.');
                await loadData();
            } catch (error) {
                alert('Error de red al eliminar materia.');
            }
        }

        async function deletePlan(idPlan) {
            if (!confirm(`¿Eliminar el plan ${idPlan}?`)) return;
            try {
                const res = await fetch(`/api/catalogos/planes/${idPlan}`, {
                    method: 'DELETE'
                });
                const data = await res.json();
                if (!res.ok) {
                    if (data.code === 'NO_DESTINO_VALIDO') {
                        return alert(data.error || 'No existe otro plan de la misma carrera con materias para reasignar.');
                    }
                    return alert(data.error || 'No se pudo eliminar el plan.');
                }

                if (Number(data.idPlanDestino) > 0) {
                    alert(
                        `${data.message || 'Plan eliminado con reasignación automática.'}\n` +
                        `Plan destino: ${data.idPlanDestino}\n` +
                        `Alumnos reasignados: ${data.alumnosReasignados || 0}\n` +
                        `Consultas reasignadas: ${data.consultasReasignadas || 0}`
                    );
                }
                await loadData();
            } catch (error) {
                alert('Error de red al eliminar plan.');
            }
        }

