        // Poblar lista de materias para el modal Pensum
        function populatePensumMaterias() {
            const list = document.getElementById('pensumMateriasList');
            if (!list) return;
            list.innerHTML = '';

            if (!pensumMateriasData || pensumMateriasData.length === 0) {
                list.innerHTML = '<p class="text-xs text-slate-400 italic">No hay materias registradas.</p>';
                return;
            }

            // Usar un Set para evitar duplicados visuales si una materia está en varios planes
            const uniqueMaterias = [];
            const codes = new Set();
            pensumMateriasData.forEach(m => {
                if (!codes.has(m.CodigoMateria)) {
                    codes.add(m.CodigoMateria);
                    uniqueMaterias.push(m);
                }
            });

            uniqueMaterias.sort((a, b) => a.NombreMateria.localeCompare(b.NombreMateria)).forEach(m => {
                const div = document.createElement('div');
                div.className = 'flex items-center space-x-2 p-1 hover:bg-white rounded transition';
                div.innerHTML = `
                    <input type="checkbox" id="m-${m.CodigoMateria}" value="${m.CodigoMateria}" class="materia-checkbox rounded text-[#B20000] focus:ring-red-500">
                    <label for="m-${m.CodigoMateria}" class="text-xs text-slate-700 cursor-pointer flex-1">
                        <span class="font-bold">${m.CodigoMateria}</span> - ${m.NombreMateria}
                    </label>
                `;
                list.appendChild(div);
            });

            const hint = document.createElement('p');
            hint.className = 'text-[10px] text-slate-400 italic mt-2';
            hint.textContent = 'Mostrando hasta 300 resultados. Usa el buscador para afinar.';
            list.appendChild(hint);
        }

        // Filtrar planes según la carrera seleccionada
        function filterPlanesForMateria() {
            // Esta función ya no es necesaria en el nuevo flujo de Nueva Materia, 
            // pero la mantenemos por si se usa en otros lados o para evitar errores.
            const carreraSelect = document.getElementById('carreraMateria');
            if (!carreraSelect) return;
            const carreraCod = carreraSelect.value;
            const planSelect = document.getElementById('planMateria');
            if (!planSelect) return;

            planSelect.innerHTML = '<option value="">Seleccione un plan...</option>';

            if (!carreraCod) return;

            const planes = planesData.filter(p => p.CodigoCarrera === carreraCod);
            planes.forEach(p => {
                const opt = document.createElement('option');
                opt.value = p.IdPlan;
                opt.textContent = `${p.NombrePlan} (${p.AnioPlan})`;
                planSelect.appendChild(opt);
            });
        }

        // Form Submit: Carrera
        document.getElementById('carreraForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const body = {
                codigo: document.getElementById('codigoCarrera').value,
                nombre: document.getElementById('nombreCarrera').value,
                nombrePlan: document.getElementById('nombrePlanCarrera').value,
                anioPlan: document.getElementById('anioPlanCarrera').value
            };
            try {
                const res = await fetch('/api/catalogos/carreras', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();

                if (!res.ok) {
                    alert(data.error || "Error al crear carrera");
                } else {
                    alert(data.message || "Carrera/Plan creado exitosamente");
                    closeModal('carreraModal');
                    e.target.reset();
                    loadData();
                }
            } catch (e) { alert("Error de red"); }
        });

        // Form Submit: Materia
        document.getElementById('materiaForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const body = {
                codigo: document.getElementById('codigoMateria').value,
                nombre: document.getElementById('nombreMateria').value,
                uvs: document.getElementById('uvsMateria').value
            };
            try {
                const res = await fetch('/api/catalogos/materias', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();

                if (!res.ok) {
                    alert(data.error || "Error al crear materia");
                } else {
                    alert(data.message || "Materia agregada exitosamente");
                    closeModal('materiaModal');
                    e.target.reset();
                    loadData();
                }
            } catch (e) { alert("Error de red"); }
        });

        // Form Submit: Plan de Estudio (Pensum)
        document.getElementById('pensumForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const selectedMaterias = Array.from(document.querySelectorAll('.materia-checkbox:checked')).map(cb => cb.value);

            const body = {
                codigoCarrera: document.getElementById('pensumCarreraSelect').value,
                nombrePlan: document.getElementById('pensumNombrePlan').value,
                anioPlan: document.getElementById('pensumAnioPlan').value,
                materias: selectedMaterias
            };
            try {
                const res = await fetch('/api/catalogos/planes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();
                if (!res.ok) {
                    alert(data.error || "Error al crear el plan");
                } else {
                    alert(data.message || "Plan de Estudio creado exitosamente");
                    closeModal('pensumModal');
                    e.target.reset();
                    loadData();
                }
            } catch (e) { alert("Error de red"); }
        });

        // Upload Excel Handling
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileNameSpan = document.getElementById('fileName');
        const fileInfo = document.getElementById('fileInfo');

        dropZone.onclick = () => fileInput.click();

        fileInput.onchange = (e) => {
            if (e.target.files.length) {
                fileInfo.classList.remove('hidden');
                fileNameSpan.textContent = e.target.files[0].name;
                dropZone.classList.add('border-[#B20000]', 'bg-red-50');
            }
        };

        dropZone.ondragover = (e) => { e.preventDefault(); dropZone.classList.add('border-[#B20000]', 'bg-red-50'); };
        dropZone.ondragleave = (e) => { e.preventDefault(); dropZone.classList.remove('border-[#B20000]', 'bg-red-50'); };
        dropZone.ondrop = (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-[#B20000]', 'bg-red-50');
            if (e.dataTransfer.files.length) {
                fileInput.files = e.dataTransfer.files;
                fileInfo.classList.remove('hidden');
                fileNameSpan.textContent = e.dataTransfer.files[0].name;
                dropZone.classList.add('border-[#B20000]', 'bg-red-50');
            }
        };

        document.getElementById('uploadForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            if (!fileInput.files.length) return alert('Selecciona un archivo primero');

            const btn = document.getElementById('btnSubmitUpload');
            btn.disabled = true;
            btn.textContent = 'Procesando...';

            const formData = new FormData();
            formData.append('archivoCatalogo', fileInput.files[0]);

            try {
                const response = await fetch('/api/catalogos/upload', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    const filas = data.filasProcesadas ?? data.recordsProcessed ?? 0;
                    const lote = data.idLote ? `\nLote: ${data.idLote}` : '';
                    alert(`Éxito!\nFilas procesadas: ${filas}${lote}`);
                    closeModal('uploadModal');
                    fileInfo.classList.add('hidden');
                    dropZone.classList.remove('border-[#B20000]', 'bg-red-50');
                    e.target.reset();
                    loadData();
                } else {
                    if (data.error === 'VALIDATION_FAILED' && Array.isArray(data.missingHeaders) && data.missingHeaders.length) {
                        alert(`Error de plantilla.\nFaltan columnas obligatorias:\n- ${data.missingHeaders.join('\n- ')}`);
                    } else if (data.error === 'VALIDATION_FAILED' && Array.isArray(data.errors) && data.errors.length) {
                        const first = data.errors[0];
                        alert(`Error de validación en fila ${first.rowNumber || '?'}: ${first.message || 'dato inválido'}`);
                    } else {
                        alert('Error: ' + (data.error || 'Server error'));
                    }
                }
            } catch (error) {
                alert('Error de conexión con el servidor.');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Importar y Procesar';
            }
        });

        function renderPdfPreviewRows() {
            const tbody = document.getElementById('pdfPreviewBody');
            if (!tbody) return;
            if (!pdfPreviewRows.length) {
                tbody.innerHTML = '<tr><td colspan="4" class="px-3 py-4 text-center text-slate-400">Sin filas para mostrar.</td></tr>';
                return;
            }

            tbody.innerHTML = pdfPreviewRows.map((row, idx) => `
                <tr class="border-t border-slate-100">
                    <td class="px-2 py-2">
                        <input type="text" class="js-preview-codigo w-full px-2 py-1 border border-slate-300 rounded"
                            value="${escapeHtml(row.codigoClase || '')}" data-idx="${idx}">
                    </td>
                    <td class="px-2 py-2">
                        <input type="text" class="js-preview-nombre w-full px-2 py-1 border border-slate-300 rounded"
                            value="${escapeHtml(row.nombreClase || '')}" data-idx="${idx}">
                    </td>
                    <td class="px-2 py-2 text-center">
                        <input type="number" min="0" class="js-preview-uv w-20 px-2 py-1 border border-slate-300 rounded text-center"
                            value="${Number(row.uv) || 0}" data-idx="${idx}">
                    </td>
                    <td class="px-2 py-2 text-center">
                        <button type="button" class="btn-min btn-min-danger btn-preview-remove" data-idx="${idx}">Quitar</button>
                    </td>
                </tr>
            `).join('');

            document.querySelectorAll('.btn-preview-remove').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const idx = Number(btn.dataset.idx);
                    pdfPreviewRows.splice(idx, 1);
                    renderPdfPreviewRows();
                });
            });
        }

        function collectPdfPreviewRowsFromTable() {
            const codigos = document.querySelectorAll('.js-preview-codigo');
            const nombres = document.querySelectorAll('.js-preview-nombre');
            const uvs = document.querySelectorAll('.js-preview-uv');
            const rows = [];

            for (let i = 0; i < codigos.length; i++) {
                rows.push({
                    codigoClase: codigos[i].value.trim().toUpperCase(),
                    nombreClase: nombres[i].value.trim(),
                    uv: Number(uvs[i].value)
                });
            }
            return rows;
        }

        // Convertir PDF de pensum con previsualización editable
        document.getElementById('convertPdfForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const pdfInput = document.getElementById('pensumPdfInput');
            if (!pdfInput.files.length) return alert('Selecciona un PDF primero');

            const btn = document.getElementById('btnConvertPdf');
            btn.disabled = true;
            btn.textContent = 'Previsualizando...';

            const formData = new FormData();
            formData.append('archivoPdf', pdfInput.files[0]);

            const codigoCarrera = document.getElementById('pdfCodigoCarrera').value.trim();
            const anioPlan = document.getElementById('pdfAnioPlan').value.trim();
            if (codigoCarrera) formData.append('codigoCarrera', codigoCarrera);
            if (anioPlan) formData.append('anioPlan', anioPlan);

            try {
                const response = await fetch('/api/catalogos/templates/preview-pdf-pensum', {
                    method: 'POST',
                    body: formData
                });
                const data = await response.json();
                if (!response.ok) return alert(data.error || 'No se pudo previsualizar el PDF');

                document.getElementById('pdfCodigoCarrera').value = data.codigoCarrera || codigoCarrera;
                document.getElementById('pdfAnioPlan').value = data.anioPlan || anioPlan;

                pdfPreviewRows = Array.isArray(data.materias) ? data.materias : [];
                document.getElementById('pdfPreviewSection').classList.remove('hidden');
                renderPdfPreviewRows();
            } catch (error) {
                alert('Error de conexión con el servidor.');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Previsualizar';
            }
        });

        document.getElementById('btnAddPreviewRow')?.addEventListener('click', () => {
            pdfPreviewRows.push({ codigoClase: '', nombreClase: '', uv: 0 });
            renderPdfPreviewRows();
        });

        document.getElementById('btnDownloadPreviewExcel')?.addEventListener('click', async () => {
            const codigoCarrera = document.getElementById('pdfCodigoCarrera').value.trim().toUpperCase();
            const anioPlan = Number(document.getElementById('pdfAnioPlan').value);
            const materias = collectPdfPreviewRowsFromTable();

            if (!codigoCarrera) return alert('Codigo de carrera requerido.');
            if (!Number.isInteger(anioPlan) || anioPlan <= 0) return alert('Año de plan inválido.');
            if (!materias.length) return alert('Agrega al menos una materia.');

            try {
                const response = await fetch('/api/catalogos/templates/generate-pensum-from-preview', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ codigoCarrera, anioPlan, materias })
                });

                const contentType = response.headers.get('content-type') || '';
                if (!response.ok) {
                    const errorData = contentType.includes('application/json')
                        ? await response.json()
                        : { error: 'No se pudo generar el Excel' };
                    return alert(errorData.error || 'No se pudo generar el Excel');
                }

                const blob = await response.blob();
                const downloadUrl = window.URL.createObjectURL(blob);
                const disposition = response.headers.get('content-disposition') || '';
                const filenameMatch = disposition.match(/filename="([^"]+)"/);
                const filename = filenameMatch ? filenameMatch[1] : 'plantilla_pensum_convertida.xlsx';

                const a = document.createElement('a');
                a.href = downloadUrl;
                a.download = filename;
                document.body.appendChild(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(downloadUrl);
            } catch (error) {
                alert('Error de conexión con el servidor.');
            }
        });

        document.getElementById('btnModalEditData')?.addEventListener('click', openModalPlanEdit);
        document.getElementById('btnModalCancelEdit')?.addEventListener('click', closeModalPlanEdit);
        document.getElementById('btnModalSaveEdit')?.addEventListener('click', saveModalPlanEdit);
        document.getElementById('btnModalAddMateria')?.addEventListener('click', async () => {
            if (!modalPlanContext) return;

            const select = document.getElementById('modalAddMateriaSelect');
            const semestreInput = document.getElementById('modalAddSemestreInput');
            const codigoMateria = select?.value?.trim()?.toUpperCase();
            const semestreRaw = semestreInput?.value?.trim();
            const semestre = semestreRaw === '' ? null : Number(semestreRaw);

            if (!codigoMateria) {
                alert('Selecciona una materia para agregar.');
                return;
            }
            if (!(semestre === null || (Number.isInteger(semestre) && semestre > 0))) {
                alert('Semestre debe ser entero positivo o vacío.');
                return;
            }

            try {
                const res = await fetch(`/api/catalogos/planes/${modalPlanContext.idPlan}/materias`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ codigoMateria, semestre })
                });
                const data = await res.json();
                if (!res.ok) return alert(data.error || 'No se pudo agregar materia al plan.');

                if (semestreInput) semestreInput.value = '';
                await verDetallePlan(
                    modalPlanContext.idPlan,
                    modalPlanContext.nombreCarrera,
                    modalPlanContext.nombrePlan,
                    modalPlanContext.anioPlan,
                    modalPlanContext.codigoCarrera,
                    modalPlanContext.idPlan
                );
                await loadData();
            } catch (error) {
                alert('Error de red al agregar materia al plan.');
            }
        });

        document.addEventListener('click', closeAllActionMenus);

        // Inicialización con paginación de carreras
        document.addEventListener('DOMContentLoaded', () => {
            getUsuarioActual();
            applyTemplateVisibilityByRole();
            
            // Configurar controles de paginación de carreras
            const btnPrevCarreras = document.getElementById('btnPrevCarreras');
            const btnNextCarreras = document.getElementById('btnNextCarreras');
            const showAllToggle = document.getElementById('showAllCarrerasToggle');
            
            if (btnPrevCarreras) {
                btnPrevCarreras.addEventListener('click', () => {
                    if (carrerasPage > 1 && !carrerasShowAll) {
                        carrerasPage--;
                        renderCarrerasWithPagination();
                    }
                });
            }
            
            if (btnNextCarreras) {
                btnNextCarreras.addEventListener('click', () => {
                    if (carrerasPage < carrerasTotalPages && !carrerasShowAll) {
                        carrerasPage++;
                        renderCarrerasWithPagination();
                    }
                });
            }
            
            if (showAllToggle) {
                showAllToggle.addEventListener('change', (e) => {
                    carrerasShowAll = e.target.checked;
                    if (!carrerasShowAll) carrerasPage = 1;
                    renderCarrerasWithPagination();
                });
            }
            
            // Configurar controles de materias (existentes)
            const materiasSearchInput = document.getElementById('materiasSearchInput');
            const btnPrevMaterias = document.getElementById('btnPrevMaterias');
            const btnNextMaterias = document.getElementById('btnNextMaterias');
            const pensumMateriasSearch = document.getElementById('pensumMateriasSearch');
            
            let materiasSearchTimer = null;
            if (materiasSearchInput) {
                materiasSearchInput.addEventListener('input', () => {
                    const value = materiasSearchInput.value.trim();
                    clearTimeout(materiasSearchTimer);
                    materiasSearchTimer = setTimeout(async () => {
                        materiasLoaded = false;
                        await fetchMateriasPage(1, value);
                    }, 250);
                });
            }
            
            if (btnPrevMaterias) {
                btnPrevMaterias.addEventListener('click', async () => {
                    if (materiasPage <= 1) return;
                    await fetchMateriasPage(materiasPage - 1, materiasSearchTerm);
                });
            }
            
            if (btnNextMaterias) {
                btnNextMaterias.addEventListener('click', async () => {
                    if (materiasPage >= materiasTotalPages) return;
                    await fetchMateriasPage(materiasPage + 1, materiasSearchTerm);
                });
            }
            
            let pensumSearchTimer = null;
            if (pensumMateriasSearch) {
                pensumMateriasSearch.addEventListener('input', () => {
                    const term = pensumMateriasSearch.value.trim();
                    clearTimeout(pensumSearchTimer);
                    pensumSearchTimer = setTimeout(() => {
                        loadPensumPickerMaterias(term);
                    }, 250);
                });
            }
            
            document.querySelectorAll('.btn-download-template').forEach((btn) => {
                btn.addEventListener('click', () => {
                    downloadTemplateAuthenticated(btn.dataset.endpoint, btn.dataset.filename || 'plantilla.xlsx');
                });
            });
            
            loadData();
        });
        
        // Sobrescribir la función loadData para usar renderCarrerasWithPagination
        const originalLoadData = loadData;
        window.loadData = async function() {
            await originalLoadData();
            renderCarrerasWithPagination();
        };
        loadData = window.loadData;
    </script>
</body>

</html>