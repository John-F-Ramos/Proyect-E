<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catálogos Académicos | CEUTEC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/auth-guard.js"></script>
    <script src="/js/profile-widget.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            overflow-x: hidden;
        }

        /* Sidebar fijo */
        .sidebar-fixed {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 50;
        }

        .main-content {
            margin-left: 256px;
            min-height: 100vh;
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }
        }

        .tab-active {
            border-bottom: 2px solid #B20000;
            color: #B20000;
            font-weight: 600;
        }

        .tab-inactive {
            border-bottom: 2px solid transparent;
            color: #64748b;
            font-weight: 500;
        }

        .carrera-row {
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .carrera-row:hover {
            background-color: #fef2f2;
        }

        .carrera-row.expanded {
            background-color: #fee2e2;
            border-left: 4px solid #B20000;
        }

        /* Estilo para la carrera y plan del usuario - rojo muy sutil */
        .carrera-row.usuario-plan {
            background-color: rgba(178, 0, 0, 0.03);
            border-left: 2px solid rgba(178, 0, 0, 0.2);
            position: relative;
        }

        .carrera-row.usuario-plan::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 0;
            width: 4px;
            background-color: #B20000;
            opacity: 0.2;
        }

        .carrera-row.usuario-plan:hover {
            background-color: rgba(178, 0, 0, 0.08);
        }

        .carrera-row.usuario-plan:hover::after {
            opacity: 0.4;
        }

        .materias-detalle {
            background-color: #f9fafb;
            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .badge-uv {
            background-color: #e6f7e6;
            color: #2e7d32;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-materias {
            background-color: #e6f0ff;
            color: #1e4b8a;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
        }

        .badge-mi-plan {
            background-color: rgba(178, 0, 0, 0.1);
            color: #B20000;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            margin-left: 8px;
        }

        /* Modal más grande */
        #planDetalleModal .bg-white {
            max-width: 1200px !important;
            width: 95% !important;
            max-height: 85vh !important;
        }

        /* Botón de descargar */
        .btn-descargar {
            background-color: #B20000;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            font-weight: 600;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }

        .btn-descargar:hover {
            background-color: #8b0000;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(178, 0, 0, 0.2);
        }

        .btn-descargar i {
            font-size: 1rem;
        }

        .btn-min {
            border: 1px solid #e2e8f0;
            background: #ffffff;
            color: #334155;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            padding: 4px 10px;
            transition: all 0.2s ease;
        }

        .btn-min:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
        }

        .btn-min-primary {
            border-color: #bfdbfe;
            color: #1d4ed8;
            background: #eff6ff;
        }

        .btn-min-primary:hover {
            background: #dbeafe;
            border-color: #93c5fd;
        }

        .btn-min-success {
            border-color: #bbf7d0;
            color: #166534;
            background: #f0fdf4;
        }

        .btn-min-success:hover {
            background: #dcfce7;
            border-color: #86efac;
        }

        .btn-min-cancel {
            border-color: #e2e8f0;
            color: #475569;
            background: #f8fafc;
        }

        .btn-min-danger {
            border-color: #fecaca;
            color: #b91c1c;
            background: #fef2f2;
        }

        .btn-min-danger:hover {
            background: #fee2e2;
            border-color: #fca5a5;
        }

        .action-menu {
            position: absolute;
            right: 0;
            top: calc(100% + 6px);
            z-index: 30;
            min-width: 180px;
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12);
            padding: 8px;
            display: none;
            flex-direction: column;
            gap: 6px;
        }

        .action-menu.open {
            display: flex;
        }

        /* Estilos para paginación */
        .pagination-btn {
            transition: all 0.2s ease;
        }
        .pagination-btn:hover:not(:disabled) {
            background-color: #f3f4f6;
            transform: translateY(-1px);
        }
        .pagination-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        @media print {
            .sidebar-fixed {
                display: none;
            }
            .main-content {
                margin-left: 0;
            }
            .no-print {
                display: none;
            }
        }
    </style>
</head>

<body class="flex min-h-screen overflow-x-hidden">
    <%- include('partials/sidebar', { active: 'plan-estudio', noPrint: false, extraAsideClasses: 'sidebar-fixed' }) %>

    <main class="flex-1 p-8 overflow-y-auto main-content">
        <header class="flex justify-between items-center mb-8 no-print">
            <div>
                <h1 class="text-2xl font-bold text-slate-800">Catálogos Académicos</h1>
                <p class="text-slate-500 text-sm mt-1">Gestión de Carreras, Planes de Estudio y Materias del sistema.
                </p>
            </div>
            <div class="flex items-center space-x-3">
                <button onclick="openModal('carreraModal')"
                    class="bg-white border border-gray-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition flex items-center">
                    <i class="fas fa-plus mr-2"></i> Nueva Carrera
                </button>
                <button onclick="openModal('materiaModal')"
                    class="bg-white border border-gray-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition flex items-center">
                    <i class="fas fa-plus mr-2"></i> Nueva Materia
                </button>
                <button onclick="openModal('pensumModal')"
                    class="bg-white border border-gray-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition flex items-center">
                    <i class="fas fa-plus mr-2"></i> Nuevo Plan
                </button>
                <button onclick="openModal('uploadModal')"
                    class="bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition flex items-center">
                    <i class="fas fa-file-excel mr-2"></i> Importar Catálogos
                </button>
                <%- include('partials/profile-widget') %>
            </div>
        </header>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="flex border-b border-gray-200 px-6 pt-4 space-x-6 no-print">
                <button onclick="switchTab('carreras')" id="tab-carreras" class="pb-3 tab-active transition">
                    Carreras y Planes de Estudio
                </button>
                <button onclick="switchTab('materias')" id="tab-materias" class="pb-3 tab-inactive transition">
                    Materias Registradas
                </button>
                <button onclick="switchTab('pensum')" id="tab-pensum" class="pb-3 tab-inactive transition">
                    Planes de Estudio (Pensum)
                </button>
                <button onclick="switchTab('templates')" id="tab-templates" class="pb-3 tab-inactive transition">
                    Plantillas de Carga
                </button>
            </div>

            <div class="p-0">
                <!-- PANEL CARRERAS CON PAGINACIÓN -->
                <div id="panel-carreras" class="block">
                    <!-- Controles de paginación para carreras -->
                    <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row gap-3 md:items-center md:justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-slate-500" id="carrerasTotalLabel">0 registros</span>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <span class="text-xs text-slate-500">Paginación</span>
                                <input type="checkbox" id="showAllCarrerasToggle" class="sr-only peer">
                                <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-red-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#B20000]"></div>
                                <span class="text-xs font-medium text-slate-600">Ver todo</span>
                            </label>
                        </div>
                        <div class="flex items-center gap-2">
                            <button id="btnPrevCarreras" class="pagination-btn px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">
                                <i class="fas fa-chevron-left text-xs"></i> Anterior
                            </button>
                            <span id="carrerasPageInfo" class="text-xs text-slate-600 min-w-[90px] text-center">1 / 1</span>
                            <button id="btnNextCarreras" class="pagination-btn px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">
                                Siguiente <i class="fas fa-chevron-right text-xs"></i>
                            </button>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left text-gray-500">
                            <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-4 rounded-tl-lg">Código</th>
                                    <th scope="col" class="px-6 py-4">Carrera</th>
                                    <th scope="col" class="px-6 py-4">Plan de Estudio</th>
                                    <th scope="col" class="px-6 py-4 text-center">Total Materias</th>
                                    <th scope="col" class="px-6 py-4 text-center">Total UVs</th>
                                    <th scope="col" class="px-6 py-4 text-center">Año</th>
                                    <th scope="col" class="px-6 py-4 text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="carrerasBody" class="divide-y divide-gray-100">
                                <tr>
                                    <td colspan="7" class="px-6 py-4 text-center">Cargando carreras...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- PANEL MATERIAS (con paginación existente) -->
                <div id="panel-materias" class="hidden">
                    <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row gap-3 md:items-center md:justify-between">
                        <div class="flex items-center gap-2">
                            <input id="materiasSearchInput" type="text" placeholder="Buscar por código o nombre..."
                                class="w-72 max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-[#B20000] focus:border-[#B20000]">
                            <span id="materiasTotalLabel" class="text-xs text-slate-500">0 materias</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <button id="btnPrevMaterias" class="pagination-btn px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">Anterior</button>
                            <span id="materiasPageInfo" class="text-xs text-slate-600 min-w-[90px] text-center">1 / 1</span>
                            <button id="btnNextMaterias" class="pagination-btn px-3 py-1.5 border border-gray-300 rounded-lg text-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed">Siguiente</button>
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left text-gray-500">
                            <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-4 rounded-tl-lg">Código</th>
                                    <th scope="col" class="px-6 py-4">Nombre de la Materia</th>
                                    <th scope="col" class="px-6 py-4">UVs</th>
                                    <th scope="col" class="px-6 py-4">Carrera</th>
                                    <th scope="col" class="px-6 py-4">Año Plan</th>
                                    <th scope="col" class="px-6 py-4 text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="materiasBody" class="divide-y divide-gray-100">
                                <tr>
                                    <td colspan="6" class="px-6 py-4 text-center">Cargando materias...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- PANEL PENSUM -->
                <div id="panel-pensum" class="hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left text-gray-500">
                            <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-4 rounded-tl-lg">IdPlan</th>
                                    <th scope="col" class="px-6 py-4">Código Carrera</th>
                                    <th scope="col" class="px-6 py-4">Año Plan</th>
                                    <th scope="col" class="px-6 py-4">Nombre Plan</th>
                                    <th scope="col" class="px-6 py-4 text-center">Total Materias</th>
                                    <th scope="col" class="px-6 py-4 text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="pensumBody" class="divide-y divide-gray-100">
                                <tr>
                                    <td colspan="6" class="px-6 py-4 text-center">Cargando planes...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- PANEL TEMPLATES (sin cambios) -->
                <div id="panel-templates" class="hidden p-6">
                    <div class="mb-5 bg-amber-50 border border-amber-200 text-amber-800 text-sm rounded-lg p-3">
                        <i class="fas fa-folder-open mr-2"></i>
                        Ruta en servidor para plantillas personalizadas:
                        <code class="font-semibold">public/templates/</code>
                        (nombres esperados: <code>plantilla_pensum.xlsx</code>, <code>plantilla_reglas_equivalencia.xlsx</code> y <code>plantilla_status_alumno.xlsx</code>).
                    </div>
                    <div id="templateDownloadCards" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Cards de plantillas (igual que antes) -->
                        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800">Plantilla de Pensum</h3>
                                    <p class="text-sm text-slate-500 mt-1">Descarga el formato oficial para carga masiva de plan de estudio.</p>
                                </div>
                                <i class="fas fa-file-excel text-2xl text-[#B20000]"></i>
                            </div>
                            <div class="mt-4 text-xs text-slate-600 bg-slate-50 rounded-lg p-3">
                                <strong>Columnas obligatorias:</strong><br>
                                Codigo_Carrera, Anio_Plan, Codigo_Clase, Nombre_Clase, UV
                            </div>
                            <button type="button" class="mt-5 inline-flex items-center bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition btn-download-template" data-endpoint="/api/catalogos/templates/pensum" data-filename="plantilla_pensum.xlsx">
                                <i class="fas fa-download mr-2"></i> Descargar plantilla
                            </button>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800">Plantilla de Reglas de Equivalencia</h3>
                                    <p class="text-sm text-slate-500 mt-1">Descarga el formato oficial para reglas internas y externas.</p>
                                </div>
                                <i class="fas fa-scale-balanced text-2xl text-[#B20000]"></i>
                            </div>
                            <div class="mt-4 text-xs text-slate-600 bg-slate-50 rounded-lg p-3">
                                <strong>Columnas obligatorias:</strong><br>
                                Tipo_Equivalencia, Universidad_Origen, Codigo_Origen, Codigo_Destino, Condicion
                            </div>
                            <button type="button" class="mt-5 inline-flex items-center bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition btn-download-template" data-endpoint="/api/catalogos/templates/reglas-equivalencia" data-filename="plantilla_reglas_equivalencia.xlsx">
                                <i class="fas fa-download mr-2"></i> Descargar plantilla
                            </button>
                        </div>
                        <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800">Plantilla de Estado de Alumno</h3>
                                    <p class="text-sm text-slate-500 mt-1">Descarga el formato oficial para actualización masiva de estado de alumnos.</p>
                                </div>
                                <i class="fas fa-user-check text-2xl text-[#B20000]"></i>
                            </div>
                            <div class="mt-4 text-xs text-slate-600 bg-slate-50 rounded-lg p-3">
                                <strong>Archivo esperado:</strong><br>
                                plantilla_status_alumno.xlsx
                            </div>
                            <button type="button" class="mt-5 inline-flex items-center bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition btn-download-template" data-endpoint="/api/catalogos/templates/status-alumno" data-filename="plantilla_status_alumno.xlsx">
                                <i class="fas fa-download mr-2"></i> Descargar plantilla
                            </button>
                        </div>
                    </div>
                    <div id="templateNoPermissionNotice" class="hidden mt-5 bg-blue-50 border border-blue-200 text-blue-800 rounded-lg p-4 text-sm">
                        <i class="fas fa-circle-info mr-2"></i>
                        Tu perfil no tiene permiso para descargar plantillas de carga.
                    </div>
                    <div class="mt-6 bg-slate-50 border border-slate-200 rounded-xl p-5">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                            <div>
                                <h3 class="text-base font-semibold text-slate-800">Prueba: convertir PDF de pensum a plantilla</h3>
                                <p class="text-sm text-slate-500">Sube un PDF de pensum y descarga un Excel listo para cargar en formato oficial.</p>
                            </div>
                            <button onclick="openModal('convertPdfModal')" class="inline-flex items-center bg-slate-800 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-slate-700 transition">
                                <i class="fas fa-file-pdf mr-2"></i> Convertir PDF a XLSX
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- MODALES (mantener todos los modales existentes) -->
    <!-- Modal Upload Excel -->
    <div id="uploadModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 transform transition-all">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-slate-800">Importar Catálogos</h3>
                <button onclick="closeModal('uploadModal')" class="text-slate-400 hover:text-slate-600 transition">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form id="uploadForm" class="space-y-6">
                <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-[#B20000] transition group cursor-pointer" id="dropZone">
                    <i class="fas fa-cloud-upload-alt text-4xl text-slate-300 group-hover:text-[#B20000] mb-4"></i>
                    <p class="text-sm text-slate-600 mb-2">Arrastra el archivo Excel (Diccionario)</p>
                    <p class="text-xs text-slate-400 font-medium italic">o haz clic para buscar</p>
                    <input type="file" id="fileInput" name="archivoCatalogo" accept=".xlsx, .xls" class="hidden" required>
                </div>
                <div id="fileInfo" class="hidden bg-slate-50 p-3 rounded-lg flex items-center text-xs text-slate-600">
                    <i class="fas fa-file-excel text-[#B20000] mr-2"></i>
                    <span id="fileName" class="truncate flex-1 font-medium">archivo.xlsx</span>
                </div>
                <button type="submit" id="btnSubmitUpload" class="w-full bg-slate-800 text-white py-3 rounded-xl font-bold hover:bg-slate-700 transition">
                    Importar y Procesar
                </button>
            </form>
        </div>
    </div>

    <!-- Modal Convertir PDF de Pensum -->
    <div id="convertPdfModal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 transform transition-all">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold text-slate-800">Convertir PDF a plantilla</h3>
                <button onclick="closeModal('convertPdfModal')" class="text-slate-400 hover:text-slate-600 transition">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form id="convertPdfForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">PDF de Pensum</label>
                    <input type="file" id="pensumPdfInput" accept=".pdf" required class="w-full px-3 py-2 border border-gray-300 rounded-lg bg-white text-sm">
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Codigo Carrera (opcional)</label>
                        <input type="text" id="pdfCodigoCarrera" placeholder="Ej: I-09" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    </div>
                    <div>
