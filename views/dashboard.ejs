<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | CEUTEC Equivalencias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
    </style>
</head>

<body class="flex min-h-screen">

    <aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col">
        <div class="p-6">
            <img src="/assets/images/logo-ceutec.png" alt="CEUTEC" class="h-10 mb-8">
            <nav class="space-y-1">
                <a href="/dashboard"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition group">
                    <i class="fas fa-home mr-3 text-gray-400 group-hover:text-[#B20000]"></i> Panel
                </a>
                <a href="/equivalencias"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-exchange-alt mr-3 text-gray-400"></i> Mis Equivalencias
                </a>
                <a href="/plan-estudio"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-book mr-3 text-gray-400"></i> Plan de Estudio
                </a>
                <a href="/reportes"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-file-alt mr-3 text-gray-400"></i> Reportes
                </a>
                <a href="/perfil"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-user mr-3 text-gray-400"></i> Mi Perfil
                </a>
            </nav>
        </div>
        <div class="mt-auto p-6 border-t border-gray-200">
            <button onclick="localStorage.removeItem('user'); window.location.href='/';" class="flex items-center w-full px-4 py-3 text-red-600 hover:bg-red-50 rounded-lg transition font-medium">
                <i class="fas fa-sign-out-alt mr-3"></i> Cerrar Sesión
            </button>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <header class="flex justify-between items-center mb-8">
            <h1 id="welcomeTitle" class="text-2xl font-bold text-slate-800">Estudiante:</h1>
            <div class="flex items-center space-x-4">
                <!-- Buscador de Alumno -->
                <div class="relative">
                    <input type="text" list="alumnosList" id="alumnoInput" placeholder="Buscar Alumno..."
                        class="bg-white border text-sm rounded-lg border-gray-300 focus:ring-blue-500 focus:border-blue-500 block p-2.5 text-slate-600 shadow-sm min-w-[250px] placeholder-gray-400">
                    <datalist id="alumnosList"></datalist>
                    <i class="fas fa-search absolute right-3 top-3 text-gray-400 pointer-events-none"></i>
                </div>

                <button id="btnOpenModal"
                    class="bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition flex items-center">
                    <i class="fas fa-file-excel mr-2"></i> Importar Historial
                </button>
                <i class="far fa-calendar text-slate-400"></i>
                <i class="far fa-bell text-slate-400"></i>
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-[#B20000]">
                    <i class="fas fa-user"></i>
                </div>
            </div>
        </header>

        <!-- MODAL DE UPLOAD EXCEL -->
        <div id="uploadModal"
            class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
            <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-8 transform transition-all">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-slate-800">Importar XML / Excel</h3>
                    <button id="btnCloseModal" class="text-slate-400 hover:text-slate-600">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <form id="uploadForm" class="space-y-6">
                    <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-[#B20000] transition group cursor-pointer"
                        id="dropZone">
                        <i class="fas fa-cloud-upload-alt text-4xl text-slate-300 group-hover:text-[#B20000] mb-4"></i>
                        <p class="text-sm text-slate-600 mb-2">Arrastra tu archivo Excel aquí</p>
                        <p class="text-xs text-slate-400 font-medium italic">o haz clic para buscar</p>
                        <input type="file" id="excelFile" name="archivo" class="hidden" accept=".xlsx, .xls">
                    </div>

                    <div id="fileInfo"
                        class="hidden bg-slate-50 p-3 rounded-lg flex items-center text-xs text-slate-600">
                        <i class="fas fa-file-excel text-[#B20000] mr-2"></i>
                        <span id="fileName" class="truncate flex-1 font-medium">archivo.xlsx</span>
                    </div>

                    <button type="submit" id="btnSubmit"
                        class="w-full bg-slate-800 text-white py-3 rounded-xl font-bold hover:bg-slate-700 transition transform hover:scale-[1.02] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                        Comenzar Procesamiento
                    </button>
                </form>

                <div id="statusMessage" class="mt-4 text-center text-sm hidden"></div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 text-center">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Progreso Curricular <i class="far fa-clock"></i>
                </h3>
                <div class="relative inline-flex items-center justify-center mb-4">
                    <svg class="w-32 h-32">
                        <circle class="text-gray-100" stroke-width="8" stroke="currentColor" fill="transparent" r="50"
                            cx="64" cy="64" />
                        <circle id="progressCircle" class="text-[#B20000] transition-all duration-1000 ease-out"
                            stroke-width="8" stroke-dasharray="314" stroke-dashoffset="314" stroke-linecap="round"
                            stroke="currentColor" fill="transparent" r="50" cx="64" cy="64" />
                    </svg>
                    <span id="progressPercentageText" class="absolute text-2xl font-bold">0%</span>
                </div>
                <p id="planDetailsText" class="text-xs text-slate-400">Seleccione un alumno</p>
                <div class="flex justify-around mt-4 pt-4 border-t">
                    <div>
                        <p id="totalUvsText" class="text-lg font-bold">0</p>
                        <p class="text-[10px] text-slate-400">Total UVs Plan</p>
                    </div>
                    <div>
                        <p id="aprobadasUvsText" class="text-lg font-bold text-[#B20000]">0</p>
                        <p class="text-[10px] text-slate-400">UVs Aprobadas</p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Resumen de Equivalencias <i class="fas fa-sliders-h"></i>
                </h3>
                <div class="h-32 flex items-end justify-around space-x-2 mb-4">
                    <div class="w-8 bg-slate-800 rounded-t h-[80%]"></div>
                    <div class="w-8 bg-red-400 rounded-t h-[20%]"></div>
                    <div class="w-8 bg-orange-300 rounded-t h-[5%]"></div>
                </div>
                <div class="grid grid-cols-3 text-center text-[10px]">
                    <div><span id="statAprobadas" class="font-bold block text-lg">0</span> Aprobadas</div>
                    <div><span class="font-bold block text-lg">-</span> En Proceso</div>
                    <div><span class="font-bold block text-lg">-</span> Pendientes</div>
                </div>
                <button
                    class="w-full mt-4 bg-slate-800 text-white py-2 rounded-lg text-xs font-semibold hover:bg-slate-700">Analizar
                    Nuevo Plan</button>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Asignaturas Pendientes <i class="far fa-clock text-red-400"></i>
                </h3>
                <div class="flex justify-center mb-4">
                    <div
                        class="w-32 h-32 rounded-full border-[12px] border-slate-800 flex items-center justify-center relative">
                        <div class="absolute inset-0 border-[12px] border-red-500 rounded-full"
                            style="clip-path: polygon(50% 50%, 100% 0, 100% 100%, 0 100%);"></div>
                        <span class="text-center leading-tight font-bold text-xs uppercase">Clases<br>Pendientes</span>
                    </div>
                </div>
                <div class="space-y-1 text-[10px]">
                    <div class="flex items-center"><span class="w-2 h-2 bg-slate-800 rounded-full mr-2"></span>
                        Fundamentales <span class="ml-auto font-bold">12</span></div>
                    <div class="flex items-center"><span class="w-2 h-2 bg-red-400 rounded-full mr-2"></span> Optativas
                        <span class="ml-auto">clases</span>
                    </div>
                    <div class="flex items-center"><span class="w-2 h-2 bg-orange-300 rounded-full mr-2"></span>
                        Técnicas <span class="ml-auto text-slate-400">restante</span></div>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Ruta Óptima Sugerida <i class="fas fa-download text-slate-400"></i>
                </h3>
                <div class="space-y-4 mb-6">
                    <div class="flex items-start">
                        <div class="mr-3 mt-1">
                            <div class="w-2 h-2 bg-slate-800 rounded-full"></div>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold">Q3 2024 • Base de Datos I</p>
                            <p class="text-[9px] text-slate-400">27 de de 2024</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <div class="mr-3 mt-1">
                            <div class="w-2 h-2 bg-slate-800 rounded-full"></div>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold">Q3 2024 • Programación III</p>
                            <p class="text-[9px] text-slate-400">21 de de 2024</p>
                        </div>
                    </div>
                </div>
                <button
                    class="w-full bg-slate-800 text-white py-2 rounded-lg text-xs font-semibold flex items-center justify-center">
                    Descargar Ruta PDF
                </button>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100">
                <h3 class="font-bold text-slate-800">Historial de Equivalencias Recientes</h3>
            </div>
            <table class="w-full text-left">
                <thead class="bg-slate-50 text-slate-400 text-[10px] uppercase font-semibold">
                    <tr>
                        <th class="px-6 py-4">Código Clase</th>
                        <th class="px-6 py-4">Nombre Asignatura</th>
                        <th class="px-6 py-4">Nota</th>
                        <th class="px-6 py-4">Estado</th>
                    </tr>
                </thead>
                <tbody id="historialTableBody" class="divide-y divide-gray-100 text-sm">
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-slate-400 italic">
                            Selecciona un alumno para ver su historial.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </main>
    <script>
        const modal = document.getElementById('uploadModal');
        const btnOpen = document.getElementById('btnOpenModal');
        const btnClose = document.getElementById('btnCloseModal');
        const form = document.getElementById('uploadForm');
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('excelFile');
        const fileInfo = document.getElementById('fileInfo');
        const fileName = document.getElementById('fileName');
        const statusMsg = document.getElementById('statusMessage');
        const btnSubmit = document.getElementById('btnSubmit');

        // Lógica Modal
        btnOpen.onclick = () => {
            modal.classList.remove('hidden');
        };

        btnClose.onclick = () => {
            modal.classList.add('hidden');
            statusMsg.classList.add('hidden');
            fileInfo.classList.add('hidden');
            form.reset();
        };

        // Drag & Drop
        dropZone.onclick = () => fileInput.click();

        fileInput.onchange = (e) => {
            if (e.target.files.length) {
                fileInfo.classList.remove('hidden');
                fileName.textContent = e.target.files[0].name;
            }
        };

        // Envío de Formulario
        form.onsubmit = async (e) => {
            e.preventDefault();
            const file = fileInput.files[0];
            if (!file) {
                showStatus('Por favor selecciona un archivo', 'text-red-600');
                return;
            }

            const formData = new FormData();
            formData.append('archivo', file);

            try {
                btnSubmit.disabled = true;
                btnSubmit.textContent = 'Procesando...';
                showStatus('Subiendo y analizando archivo...', 'text-blue-600');

                const response = await fetch('/api/ingest/upload', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    showStatus(`¡Éxito! Se procesaron ${data.recordsProcessed} registros.`, 'text-green-600');
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showStatus(data.error || 'Error al procesar el archivo', 'text-red-600');
                }
            } catch (error) {
                showStatus('Error de conexión con el servidor', 'text-red-600');
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.textContent = 'Comenzar Procesamiento';
            }
        };

        const ALUMNO_INPUT = document.getElementById('alumnoInput');
        const ALUMNOS_LIST = document.getElementById('alumnosList');
        const WELCOME_TITLE = document.getElementById('welcomeTitle');

        // Referencias Métricas
        const CIRCLE = document.getElementById('progressCircle');
        const PERC_TEXT = document.getElementById('progressPercentageText');
        const TOTAL_UVS = document.getElementById('totalUvsText');
        const APRO_UVS = document.getElementById('aprobadasUvsText');
        const PLAN_DETAILS = document.getElementById('planDetailsText');
        const STAT_APROBDAS = document.getElementById('statAprobadas');
        const TABLE_BODY = document.getElementById('historialTableBody');

        // Cargar Lista de Alumnos al iniciar
        async function fetchAlumnos() {
            try {
                const res = await fetch('/api/alumnos');
                const alumnos = await res.json();

                if (alumnos.length === 0) return;

                // Guardaremos los alumnos en memoria para validar las selecciones luego
                window.alumnosData = alumnos;

                alumnos.forEach(alum => {
                    const opt = document.createElement('option');
                    // Mostraremos Cuenta - Nombre
                    opt.value = `${alum.NumeroCuenta} - ${alum.NombreCompleto}`;
                    ALUMNOS_LIST.appendChild(opt);
                });
            } catch (err) {
                console.error("Error al cargar selector:", err);
            }
        }

        // Cargar Dashboard Específico al seleccionar del datalist
        ALUMNO_INPUT.addEventListener('change', async (e) => {
            const inputValue = e.target.value;
            if (!inputValue) return;

            // Extraer cuenta si viene en formato "Cuenta - Nombre"
            // Ej: "20911091 - José Ramos" -> "20911091"
            const cuenta = inputValue.split(' - ')[0].trim();
            
            // Validamos que sea un valor real del datalist
            if (!window.alumnosData || !window.alumnosData.some(a => a.NumeroCuenta === cuenta)) {
                return; // Es texto ingresado manualmente sin autocompletar, ignoramos
            }

            try {
                WELCOME_TITLE.textContent = "Cargando...";
                
                // Animación simple
                document.getElementById('progressCircle').style.strokeDashoffset = 314;
                
                const res = await fetch('/api/alumnos/' + cuenta + '/dashboard');
                const data = await res.json();

                if (!res.ok) throw new Error(data.error);

                actualizarUICircular(data);
            } catch (err) {
                console.error(err);
                WELCOME_TITLE.textContent = "Error al cargar datos";
            }
        });

        function actualizarUICircular(data) {
            // Textos
            WELCOME_TITLE.textContent = `Estudiante: ${data.alumno.NombreCompleto}`;
            PLAN_DETAILS.innerHTML = `<b>${data.alumno.NombreCarrera || 'Sin Carrera'}</b><br/>${data.alumno.NombrePlan || 'Sin Plan'}`;

            // Progress Calculation (Visual SVG Circle)
            const uvsAprobadas = data.progreso.uvsAprobadas;
            const uvsPlan = data.progreso.totalUvsPlan;
            const porcentaje = Math.min(Math.round((uvsAprobadas / uvsPlan) * 100), 100);

            // Radio real = 50. Perímetro = 2 * PI * r = 314
            const perimetro = 314;
            const offset = perimetro - (porcentaje / 100) * perimetro;

            CIRCLE.style.strokeDashoffset = offset;
            PERC_TEXT.textContent = `${porcentaje}%`;

            TOTAL_UVS.textContent = uvsPlan;
            APRO_UVS.textContent = uvsAprobadas;
            STAT_APROBDAS.textContent = data.progreso.clasesAprobadas;

            // Historial Table
            TABLE_BODY.innerHTML = '';
            if (data.historialReciente.length === 0) {
                TABLE_BODY.innerHTML = '<tr><td colspan="4" class="px-6 py-4 text-center">No hay historial reciente.</td></tr>';
            } else {
                data.historialReciente.forEach(reg => {
                    const badgeClass = ['APB', 'APR', 'APROBADO', 'REQ'].includes(reg.Estado)
                        ? 'bg-green-100 text-green-600'
                        : 'bg-orange-100 text-orange-600';

                    TABLE_BODY.innerHTML += `
                        <tr>
                            <td class="px-6 py-4 text-slate-500">${reg.CodigoMateria}</td>
                            <td class="px-6 py-4 font-medium">${reg.NombreMateria}</td>
                            <td class="px-6 py-4 font-bold text-slate-800">${reg.Nota}</td>
                            <td class="px-6 py-4"><span class="${badgeClass} px-3 py-1 rounded-full text-[10px] font-bold uppercase">${reg.Estado}</span></td>
                        </tr>
                    `;
                });
            }
        }

        // Init
        fetchAlumnos();

        function showStatus(text, colorClass) {
            statusMsg.textContent = text;
            statusMsg.className = `mt-4 text-center text-sm font-semibold ${colorClass}`;
            statusMsg.classList.remove('hidden');
        }
    </script>
</body>

</html>