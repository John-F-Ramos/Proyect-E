<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | CEUTEC Equivalencias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/auth-guard.js"></script>
    <script src="/js/profile-widget.js"></script>
    <script src="/js/student-search-combobox.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        .metric-card {
            transition: all 0.2s ease;
        }
        .metric-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        /* Estilos para paginación */
        .pagination-btn {
            transition: all 0.2s ease;
        }
        .pagination-btn:hover:not(:disabled) {
            background-color: #f3f4f6;
            transform: translateY(-1px);
        }
        .pagination-btn:active:not(:disabled) {
            transform: translateY(0);
        }
        /* Sidebar fijo */
        .sidebar-fixed {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 50;
        }
        .main-content {
            margin-left: 256px;
            min-height: 100vh;
        }
        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }
        }
    </style>
</head>

<body class="flex min-h-screen">

    <%- include('partials/sidebar', { active: 'dashboard', noPrint: false, extraAsideClasses: 'sidebar-fixed' }) %>

    <main class="flex-1 p-8 overflow-y-auto main-content">
        <header class="flex justify-between items-center mb-8 gap-4">
            <div>
                <h1 id="welcomeTitle" class="text-2xl font-bold text-slate-800">Estudiante: Cargando...</h1>
                <p id="adminSubtitle" class="hidden text-sm text-slate-500 mt-1">Indicadores operativos de la plataforma.</p>
            </div>
            <div class="ml-auto flex items-center gap-3">
                <div id="studentSearchWrap" class="student-search-wrap relative min-w-[250px]">
                    <input type="text" id="alumnoInput" placeholder="Buscar alumno..." autocomplete="off"
                        class="bg-white border text-sm rounded-lg border-gray-300 focus:ring-[#B20000] focus:border-[#B20000] block p-2.5 text-slate-600 shadow-sm w-full placeholder-gray-400">
                </div>
                <button id="btnOpenModal"
                    class="bg-[#B20000] text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-red-700 transition flex items-center whitespace-nowrap">
                    <i class="fas fa-file-excel mr-2"></i> Importar Historial
                </button>
                <%- include('partials/profile-widget') %>
            </div>
        </header>

        <!-- MODAL DE IMPORTACIÓN -->
        <div id="uploadModal"
            class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center p-4">
            <div
                class="bg-white rounded-2xl shadow-2xl max-w-4xl w-full p-8 transform transition-all max-h-[90vh] overflow-y-auto">
                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-xl font-bold text-slate-800">Importar Historial</h3>
                    <button id="btnCloseModal" class="text-slate-400 hover:text-slate-600">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>

                <!-- Tabs -->
                <div class="flex border-b border-gray-200 mb-6" id="importTabs">
                    <button id="tabFile"
                        class="px-4 py-2 text-sm font-medium text-[#B20000] border-b-2 border-[#B20000]">Subir
                        Archivo</button>
                    <button id="tabPaste"
                        class="px-4 py-2 text-sm font-medium text-gray-500 hover:text-[#B20000] hover:border-b-2 hover:border-[#B20000]">Pegar
                        Texto</button>
                </div>

                <!-- Sección Archivo -->
                <div id="fileSection">
                    <form id="uploadForm" class="space-y-6">
                        <div class="border-2 border-dashed border-slate-200 rounded-xl p-8 text-center hover:border-[#B20000] transition group cursor-pointer"
                            id="dropZone">
                            <i
                                class="fas fa-cloud-upload-alt text-4xl text-slate-300 group-hover:text-[#B20000] mb-4"></i>
                            <p class="text-sm text-slate-600 mb-2">Arrastra tu archivo Excel aquí</p>
                            <p class="text-xs text-slate-400 font-medium italic">o haz clic para buscar</p>
                            <input type="file" id="excelFile" name="archivo" class="hidden" accept=".xlsx, .xls">
                        </div>

                        <div id="fileInfo"
                            class="hidden bg-slate-50 p-3 rounded-lg flex items-center text-xs text-slate-600">
                            <i class="fas fa-file-excel text-[#B20000] mr-2"></i>
                            <span id="fileName" class="truncate flex-1 font-medium">archivo.xlsx</span>
                        </div>

                        <button type="submit" id="btnSubmit"
                            class="w-full bg-slate-800 text-white py-3 rounded-xl font-bold hover:bg-slate-700 transition transform hover:scale-[1.02] active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                            Comenzar Procesamiento
                        </button>
                    </form>
                </div>

                <!-- Sección Texto -->
                <div id="textSection" class="hidden">
                    <div class="space-y-4">
                        <!-- Manual Account Input -->
                        <div id="manualAccountSection"
                            class="hidden bg-slate-50 p-4 rounded-xl border border-slate-200 mb-4">
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">
                                <i class="fas fa-user-graduate mr-1"></i> Cuenta del Alumno
                            </label>
                            <input type="text" id="manualAccountInput" placeholder="Ej: 61234567"
                                class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm focus:ring-[#B20000] focus:border-[#B20000]"
                                title="Ingresa la cuenta del alumno para este bloque de texto">
                            <p id="manualAccountHelp" class="text-[10px] text-slate-400 mt-2">
                                <i class="fas fa-info-circle mr-1"></i> Si dejas esto vacío, se usará el alumno
                                seleccionado en el Dashboard o la cuenta que venga en los datos.
                            </p>
                        </div>
                        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3">
                            <p class="text-xs font-semibold text-amber-800 mb-2">
                                Formato esperado (CEUTEC)
                            </p>
                            <div class="overflow-x-auto">
                                <table class="min-w-full text-[11px] text-left">
                                    <thead class="text-amber-900">
                                        <tr>
                                            <th class="pr-3 py-1">Campus</th>
                                            <th class="pr-3 py-1">Año</th>
                                            <th class="pr-3 py-1">Semestre</th>
                                            <th class="pr-3 py-1">Módulo</th>
                                            <th class="pr-3 py-1">Sección</th>
                                            <th class="pr-3 py-1">Código</th>
                                            <th class="pr-3 py-1">Materia</th>
                                            <th class="pr-3 py-1">Nota</th>
                                            <th class="pr-3 py-1">Estado</th>
                                            <th class="pr-3 py-1">UV</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-amber-800">
                                        <tr>
                                            <td class="pr-3 py-1">TGU</td>
                                            <td class="pr-3 py-1">2026</td>
                                            <td class="pr-3 py-1">1</td>
                                            <td class="pr-3 py-1">1</td>
                                            <td class="pr-3 py-1">A</td>
                                            <td class="pr-3 py-1">MAT101</td>
                                            <td class="pr-3 py-1">Matemática I</td>
                                            <td class="pr-3 py-1">89</td>
                                            <td class="pr-3 py-1">APB</td>
                                            <td class="pr-3 py-1">4</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <textarea id="pasteArea" rows="8"
                            class="w-full border border-gray-300 rounded-lg p-3 font-mono text-sm focus:ring-[#B20000] focus:border-[#B20000]"
                            placeholder="Pega aquí filas con formato CEUTEC: Campus | Año | Semestre | Módulo | Sección | Código | Materia | Nota | Estado | UV"></textarea>

                        <button id="btnPreviewText"
                            class="w-full bg-[#B20000] text-white py-3 rounded-xl font-bold hover:bg-red-700 transition transform hover:scale-[1.02] active:scale-[0.98]">
                            <i class="fas fa-eye mr-2"></i> Vista Previa
                        </button>
                    </div>
                </div>

                <!-- Área de Vista Previa -->
                <div id="previewSection" class="mt-6 hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h4 class="text-lg font-semibold text-slate-800">
                            <i class="fas fa-table mr-2 text-[#B20000]"></i>
                            Vista Previa de Datos
                            <span id="previewCount" class="text-sm font-normal text-slate-500 ml-2"></span>
                        </h4>
                        <div class="space-x-2">
                            <button id="btnCancelPreview"
                                class="px-4 py-2 bg-gray-500 text-white rounded-lg text-sm font-semibold hover:bg-gray-600 transition">
                                Cancelar
                            </button>
                            <button id="btnAcceptPreview"
                                class="px-4 py-2 bg-[#B20000] text-white rounded-lg text-sm font-semibold hover:bg-red-700 transition">
                                Aceptar e Importar
                            </button>
                        </div>
                    </div>
                    <div class="overflow-x-auto border border-gray-200 rounded-lg max-h-80">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Código
                                    </th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Materia
                                    </th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Nota
                                    </th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">Estado
                                    </th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-slate-500 uppercase">UV</th>
                                </tr>
                            </thead>
                            <tbody id="previewTableBody" class="bg-white divide-y divide-gray-200 text-sm">
                                <!-- Datos de preview -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="statusMessage" class="mt-4 text-center text-sm hidden"></div>
            </div>
        </div>

        <!-- Dashboard de Administrador -->
        <div id="adminDashboard" class="hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                    <p class="text-xs text-slate-500 mb-1">Usuarios Totales</p>
                    <p id="adminTotalUsuarios" class="text-3xl font-bold text-slate-800">0</p>
                    <p class="text-xs text-slate-400 mt-2">Base total de usuarios registrados.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                    <p class="text-xs text-slate-500 mb-1">Usuarios Activos</p>
                    <p id="adminUsuariosActivos" class="text-3xl font-bold text-green-600">0</p>
                    <p class="text-xs text-slate-400 mt-2">Cuentas habilitadas para ingresar.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                    <p class="text-xs text-slate-500 mb-1">Usuarios Inactivos</p>
                    <p id="adminUsuariosInactivos" class="text-3xl font-bold text-red-600">0</p>
                    <p class="text-xs text-slate-400 mt-2">Cuentas suspendidas o desactivadas.</p>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                    <p class="text-xs text-slate-500 mb-1">Altas (últimos 7 días)</p>
                    <p id="adminAltasUltimos7Dias" class="text-3xl font-bold text-[#B20000]">0</p>
                    <p class="text-xs text-slate-400 mt-2">Nuevos usuarios creados recientemente.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                    <h3 class="text-sm font-semibold text-slate-700 mb-4">Distribución por Rol</h3>
                    <div class="space-y-3">
                        <div>
                            <div class="flex justify-between text-xs text-slate-500 mb-1">
                                <span>Administradores</span>
                                <span id="adminRolAdminCount">0</span>
                            </div>
                            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                                <div id="adminRolAdminBar" class="h-2 bg-[#B20000] rounded-full" style="width:0%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs text-slate-500 mb-1">
                                <span>Jefes de Carrera</span>
                                <span id="adminRolJefeCount">0</span>
                            </div>
                            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                                <div id="adminRolJefeBar" class="h-2 bg-blue-500 rounded-full" style="width:0%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-xs text-slate-500 mb-1">
                                <span>Estudiantes</span>
                                <span id="adminRolEstudianteCount">0</span>
                            </div>
                            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                                <div id="adminRolEstudianteBar" class="h-2 bg-green-500 rounded-full" style="width:0%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 lg:col-span-2 metric-card">
                    <h3 class="text-sm font-semibold text-slate-700 mb-4">Resumen de Plataforma</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="bg-slate-50 rounded-xl p-4">
                            <p class="text-xs text-slate-500 mb-1">Tasa de activación</p>
                            <p id="adminActivationRate" class="text-2xl font-bold text-slate-800">0%</p>
                        </div>
                        <div class="bg-slate-50 rounded-xl p-4">
                            <p class="text-xs text-slate-500 mb-1">Relación admins/jefes</p>
                            <p id="adminAdminJefeRatio" class="text-2xl font-bold text-slate-800">0:0</p>
                        </div>
                        <div class="bg-slate-50 rounded-xl p-4 sm:col-span-2">
                            <p class="text-xs text-slate-500 mb-1">Estado general</p>
                            <p id="adminPlatformHealth" class="text-sm text-slate-700">Cargando métricas...</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="academicDashboard">
        <!-- Cards del Dashboard con métricas mejoradas -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 mb-8">
            <!-- Card 1: Progreso Curricular -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 text-center metric-card">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Progreso Curricular <i class="far fa-clock"></i>
                </h3>
                <div class="relative inline-flex items-center justify-center mb-4">
                    <svg class="w-32 h-32">
                        <circle class="text-gray-100" stroke-width="8" stroke="currentColor" fill="transparent" r="50"
                            cx="64" cy="64" />
                        <circle id="progressCircle" class="text-[#B20000] transition-all duration-1000 ease-out"
                            stroke-width="8" stroke-dasharray="314" stroke-dashoffset="314" stroke-linecap="round"
                            stroke="currentColor" fill="transparent" r="50" cx="64" cy="64" />
                    </svg>
                    <span id="progressPercentageText" class="absolute text-2xl font-bold">0%</span>
                </div>
                <p id="planDetailsText" class="text-xs text-slate-400">Cargando información...</p>
                <div class="flex justify-around mt-4 pt-4 border-t">
                    <div>
                        <p id="totalUvsText" class="text-lg font-bold">0</p>
                        <p class="text-[10px] text-slate-400">Total UVs Plan</p>
                    </div>
                    <div>
                        <p id="aprobadasUvsText" class="text-lg font-bold text-[#B20000]">0</p>
                        <p class="text-[10px] text-slate-400">UVs Aprobadas</p>
                    </div>
                </div>
            </div>

            <!-- Card 2: Rendimiento Académico -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Rendimiento Académico <i class="fas fa-chart-line"></i>
                </h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-xs text-slate-400 mb-1">Índice Académico</p>
                        <p id="indiceAcademico" class="text-3xl font-bold text-[#B20000]">0.00</p>
                    </div>
                    <div class="grid grid-cols-3 gap-2 text-center">
                        <div class="bg-green-50 p-2 rounded">
                            <p id="statAprobadas" class="font-bold text-lg text-green-600">0</p>
                            <p class="text-[10px] text-green-700">Aprobadas</p>
                        </div>
                        <div class="bg-red-50 p-2 rounded">
                            <p id="statReprobadas" class="font-bold text-lg text-red-600">0</p>
                            <p class="text-[10px] text-red-700">Reprobadas</p>
                        </div>
                        <div class="bg-blue-50 p-2 rounded">
                            <p id="statEnCurso" class="font-bold text-lg text-blue-600">0</p>
                            <p class="text-[10px] text-blue-700">En Curso</p>
                        </div>
                    </div>
                    <div class="pt-2 border-t border-gray-100">
                        <p class="text-xs text-slate-400">Promedio General</p>
                        <p id="promedioGeneral" class="text-xl font-semibold">0.00</p>
                    </div>
                </div>
            </div>

            <!-- Card 3: Progreso de Materias (REDISEÑADA del segundo código) -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Progreso de Materias <i class="fas fa-chart-pie"></i>
                </h3>
                
                <!-- Métricas Principales -->
                <div class="space-y-3">
                    <!-- Materias Restantes (Destacado) -->
                    <div class="flex justify-between items-center p-2 bg-orange-50 rounded-lg">
                        <span class="text-xs font-medium text-orange-700 flex items-center">
                            <i class="fas fa-hourglass-half text-orange-500 mr-2"></i> Materias Restantes
                        </span>
                        <span id="totalMateriasRestantes" class="text-lg font-bold text-orange-600">0</span>
                    </div>
                    
                    <!-- Materias en Curso -->
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-500 flex items-center">
                            <i class="fas fa-book-open text-blue-400 mr-2"></i> Materias en Curso
                        </span>
                        <span id="statEnCursoMaterias" class="font-semibold text-blue-600">0</span>
                    </div>
                    
                    <!-- UVs en Curso -->
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-500 flex items-center">
                            <i class="fas fa-bolt text-yellow-500 mr-2"></i> UVs en Curso
                        </span>
                        <span id="totalUvsEnCurso" class="font-semibold text-yellow-600">0</span>
                    </div>
                    
                    <!-- Total Materias Aprobadas -->
                    <div class="flex justify-between items-center pt-2 border-t border-gray-100">
                        <span class="text-xs text-slate-500 flex items-center">
                            <i class="fas fa-check-circle text-green-500 mr-2"></i> Total Materias Aprobadas
                        </span>
                        <span id="statAprobadasTotal" class="font-semibold text-green-600">0</span>
                    </div>
                    
                    <!-- Total Materias Plan -->
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-slate-500 flex items-center">
                            <i class="fas fa-layer-group text-purple-500 mr-2"></i> Total Materias Plan
                        </span>
                        <span id="totalMateriasPlan" class="font-semibold text-purple-600">0</span>
                    </div>
                </div>
                
                <!-- Lista de Materias en Curso (Expandible) -->
                <div class="mt-4 pt-3 border-t border-gray-100">
                    <details class="group">
                        <summary class="text-xs font-medium text-slate-600 cursor-pointer list-none flex items-center">
                            <i class="fas fa-chevron-right mr-2 text-[10px] group-open:rotate-90 transition-transform"></i>
                            Ver materias en curso
                        </summary>
                        <div id="materiasEnCursoContainer" class="mt-2 space-y-2 max-h-28 overflow-y-auto pl-2">
                            <p class="text-xs text-slate-400 text-center py-2">Cargando...</p>
                        </div>
                    </details>
                </div>
            </div>

            <!-- Card 4: Próximas Materias Sugeridas -->
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 metric-card">
                <h3 class="text-sm font-semibold text-slate-500 mb-4 flex justify-between items-center">
                    Próximas Materias Sugeridas <i class="fas fa-arrow-right text-green-400"></i>
                </h3>
                <div id="proximasMateriasContainer" class="space-y-3 max-h-40 overflow-y-auto">
                    <p class="text-xs text-slate-400 text-center py-2">Cargando...</p>
                </div>
                <a href="/plan-estudio"
                    class="block w-full mt-3 bg-slate-800 text-white py-2 rounded-lg text-xs font-semibold hover:bg-slate-700 text-center">
                    Ver Plan de Estudio
                </a>
            </div>
        </div>

        <!-- Tabla de Historial Académico CON PAGINACIÓN Y TOGGLE PARA VER TODO -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center flex-wrap gap-4">
                <h3 class="font-bold text-slate-800">Historial Académico Reciente</h3>
                <div class="flex items-center gap-4">
                    <!-- Toggle para ver todo / paginación -->
                    <div class="flex items-center gap-2">
                        <span class="text-xs text-slate-500">Paginación</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="showAllToggle" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-red-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#B20000]"></div>
                            <span class="ml-2 text-xs font-medium text-slate-600">Ver todo</span>
                        </label>
                    </div>
                    <a href="/equivalencias" class="text-xs text-[#B20000] hover:underline">Ver Equivalencias</a>
                </div>
            </div>
            
            <!-- Tabla de historial -->
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 text-slate-400 text-[10px] uppercase font-semibold">
                        <tr>
                            <th class="px-6 py-4">Código</th>
                            <th class="px-6 py-4">Asignatura</th>
                            <th class="px-6 py-4">Nota</th>
                            <th class="px-6 py-4">Estado</th>
                            <th class="px-6 py-4">UV</th>
                        </tr>
                    </thead>
                    <tbody id="historialTableBody" class="divide-y divide-gray-100 text-sm">
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-slate-400 italic">
                                Cargando historial...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            
            <!-- Controles de paginación (se ocultan cuando "Ver todo" está activado) -->
            <div id="paginationControls" class="px-6 py-4 border-t border-gray-100 bg-slate-50">
                <div class="flex items-center justify-between">
                    <div class="text-xs text-slate-500">
                        Mostrando <span id="paginationStart">0</span> - <span id="paginationEnd">0</span> de <span id="paginationTotal">0</span> registros
                    </div>
                    <div class="flex gap-2">
                        <button id="prevPageBtn" 
                            class="pagination-btn px-3 py-1 text-sm bg-white border border-gray-300 rounded-md hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition">
                            <i class="fas fa-chevron-left text-xs"></i> Anterior
                        </button>
                        <span id="pageIndicator" class="px-3 py-1 text-sm text-slate-600">Página 1</span>
                        <button id="nextPageBtn" 
                            class="pagination-btn px-3 py-1 text-sm bg-white border border-gray-300 rounded-md hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed transition">
                            Siguiente <i class="fas fa-chevron-right text-xs"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        </div>
    </main>

    <script>
        // Obtener usuario del localStorage
        const userFromStorage = JSON.parse(localStorage.getItem('user') || '{}');
        const userAccount = userFromStorage.numeroCuenta || '';
        const userNombre = userFromStorage.nombre || '';

        console.log('Usuario logueado:', { userAccount, userNombre });

        // Elementos del DOM
        const modal = document.getElementById('uploadModal');
        const btnOpen = document.getElementById('btnOpenModal');
        const btnClose = document.getElementById('btnCloseModal');
        const form = document.getElementById('uploadForm');
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('excelFile');
        const fileInfo = document.getElementById('fileInfo');
        const fileName = document.getElementById('fileName');
        const statusMsg = document.getElementById('statusMessage');
        const btnSubmit = document.getElementById('btnSubmit');
        const userAccountDisplay = document.getElementById('userAccountDisplay');

        // Elementos para texto plano
        const tabFile = document.getElementById('tabFile');
        const tabPaste = document.getElementById('tabPaste');
        const fileSection = document.getElementById('fileSection');
        const textSection = document.getElementById('textSection');
        const pasteArea = document.getElementById('pasteArea');
        const btnPreviewText = document.getElementById('btnPreviewText');
        const previewSection = document.getElementById('previewSection');
        const previewTableBody = document.getElementById('previewTableBody');
        const previewCount = document.getElementById('previewCount');
        const btnCancelPreview = document.getElementById('btnCancelPreview');
        const btnAcceptPreview = document.getElementById('btnAcceptPreview');

        // Elementos del dashboard
        const IS_ADMIN = userFromStorage.rol === 1;
        const ALUMNO_INPUT = document.getElementById('alumnoInput');
        const STUDENT_SEARCH_WRAP = document.getElementById('studentSearchWrap');
        const WELCOME_TITLE = document.getElementById('welcomeTitle');
        const ADMIN_SUBTITLE = document.getElementById('adminSubtitle');
        const ADMIN_DASHBOARD = document.getElementById('adminDashboard');
        const ACADEMIC_DASHBOARD = document.getElementById('academicDashboard');
        const CIRCLE = document.getElementById('progressCircle');
        const PERC_TEXT = document.getElementById('progressPercentageText');
        const TOTAL_UVS = document.getElementById('totalUvsText');
        const APRO_UVS = document.getElementById('aprobadasUvsText');
        const PLAN_DETAILS = document.getElementById('planDetailsText');
        const TABLE_BODY = document.getElementById('historialTableBody');
        
        // Nuevos elementos para métricas de materias (del segundo código)
        const totalMateriasRestantes = document.getElementById('totalMateriasRestantes');
        const totalMateriasPlan = document.getElementById('totalMateriasPlan');
        const statEnCursoMaterias = document.getElementById('statEnCursoMaterias');
        const totalUvsEnCurso = document.getElementById('totalUvsEnCurso');
        const statAprobadasTotal = document.getElementById('statAprobadasTotal');

        // Elementos para paginación
        const prevPageBtn = document.getElementById('prevPageBtn');
        const nextPageBtn = document.getElementById('nextPageBtn');
        const pageIndicator = document.getElementById('pageIndicator');
        const paginationStart = document.getElementById('paginationStart');
        const paginationEnd = document.getElementById('paginationEnd');
        const paginationTotal = document.getElementById('paginationTotal');
        const paginationControls = document.getElementById('paginationControls');
        const showAllToggle = document.getElementById('showAllToggle');

        let currentPreviewData = null;
        let currentHistorialData = [];
        let currentPage = 1;
        let itemsPerPage = 10;
        let showAllMode = false;

        // Función para renderizar la tabla con o sin paginación según el toggle
        function renderHistorialWithPagination() {
            let dataToShow = currentHistorialData;
            let totalItems = currentHistorialData.length;
            
            if (!showAllMode) {
                const startIndex = (currentPage - 1) * itemsPerPage;
                const endIndex = startIndex + itemsPerPage;
                dataToShow = currentHistorialData.slice(startIndex, endIndex);
                
                // Actualizar controles de paginación
                const startItem = totalItems === 0 ? 0 : startIndex + 1;
                const endItem = Math.min(endIndex, totalItems);
                const totalPages = Math.ceil(totalItems / itemsPerPage);
                
                paginationStart.textContent = startItem;
                paginationEnd.textContent = endItem;
                paginationTotal.textContent = totalItems;
                pageIndicator.textContent = `Página ${currentPage} de ${totalPages || 1}`;
                
                prevPageBtn.disabled = currentPage === 1;
                nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;
                
                // Mostrar controles de paginación
                paginationControls.style.display = 'block';
            } else {
                // Mostrar todos los registros sin paginación
                dataToShow = currentHistorialData;
                
                // Actualizar contadores
                paginationStart.textContent = 1;
                paginationEnd.textContent = totalItems;
                paginationTotal.textContent = totalItems;
                
                // Ocultar controles de paginación
                paginationControls.style.display = 'none';
            }
            
            // Renderizar tabla
            TABLE_BODY.innerHTML = '';
            if (dataToShow.length === 0) {
                TABLE_BODY.innerHTML = '}<tr><td colspan="5" class="px-6 py-4 text-center">No hay historial disponible.</td></tr>';
            } else {
                dataToShow.forEach(reg => {
                    let badgeClass = 'bg-gray-100 text-gray-600';
                    if (reg.Estado === 'APB' || reg.Estado === 'APR' || reg.Estado === 'APROBADO') {
                        badgeClass = 'bg-green-100 text-green-600';
                    } else if (reg.Estado === 'EN CURSO') {
                        badgeClass = 'bg-blue-100 text-blue-600';
                    } else if (reg.Estado === 'REP') {
                        badgeClass = 'bg-red-100 text-red-600';
                    }

                    TABLE_BODY.innerHTML += `
                        <tr>
                            <td class="px-6 py-4 text-slate-500">${reg.CodigoMateria || '-'}</td>
                            <td class="px-6 py-4 font-medium">${reg.NombreMateria || '-'}</td>
                            <td class="px-6 py-4 font-bold text-slate-800">${reg.Nota || '-'}</td>
                            <td class="px-6 py-4"><span class="${badgeClass} px-3 py-1 rounded-full text-[10px] font-bold uppercase">${reg.Estado || '-'}</span></td>
                            <td class="px-6 py-4 text-slate-500">${reg.UVS || '-'}</td>
                        </tr>
                    `;
                });
            }
        }

        // Evento del toggle para mostrar todo / paginación
        if (showAllToggle) {
            showAllToggle.addEventListener('change', (e) => {
                showAllMode = e.target.checked;
                if (!showAllMode && currentPage === 1) {
                    // Si volvemos a paginación y estábamos en página 1, simplemente re-renderizar
                    renderHistorialWithPagination();
                } else if (!showAllMode) {
                    // Resetear a página 1 al volver a paginación
                    currentPage = 1;
                    renderHistorialWithPagination();
                } else {
                    renderHistorialWithPagination();
                }
            });
        }

        function updateRoleBar(elementId, count, total) {
            const bar = document.getElementById(elementId);
            if (!bar) return;
            const pct = total > 0 ? Math.max(0, Math.min(100, Math.round((count / total) * 100))) : 0;
            bar.style.width = `${pct}%`;
        }

        function actualizarDashboardAdmin(metrics) {
            const total = Number(metrics.totalUsuarios || 0);
            const activos = Number(metrics.usuariosActivos || 0);
            const inactivos = Number(metrics.usuariosInactivos || 0);
            const admins = Number(metrics.totalAdmins || 0);
            const jefes = Number(metrics.totalJefes || 0);
            const estudiantes = Number(metrics.totalEstudiantes || 0);
            const altas7 = Number(metrics.altasUltimos7Dias || 0);

            document.getElementById('adminTotalUsuarios').textContent = total;
            document.getElementById('adminUsuariosActivos').textContent = activos;
            document.getElementById('adminUsuariosInactivos').textContent = inactivos;
            document.getElementById('adminAltasUltimos7Dias').textContent = altas7;

            document.getElementById('adminRolAdminCount').textContent = admins;
            document.getElementById('adminRolJefeCount').textContent = jefes;
            document.getElementById('adminRolEstudianteCount').textContent = estudiantes;

            updateRoleBar('adminRolAdminBar', admins, total);
            updateRoleBar('adminRolJefeBar', jefes, total);
            updateRoleBar('adminRolEstudianteBar', estudiantes, total);

            const activationRate = total > 0 ? Math.round((activos / total) * 100) : 0;
            document.getElementById('adminActivationRate').textContent = `${activationRate}%`;
            document.getElementById('adminAdminJefeRatio').textContent = `${admins}:${jefes}`;

            const healthText = activationRate >= 90
                ? 'Plataforma estable: alta disponibilidad de cuentas activas.'
                : activationRate >= 70
                    ? 'Plataforma en estado moderado: revisar cuentas inactivas.'
                    : 'Plataforma con riesgo: alto porcentaje de cuentas inactivas.';
            document.getElementById('adminPlatformHealth').textContent = healthText;
        }

        async function cargarDashboardAdmin() {
            try {
                WELCOME_TITLE.textContent = 'Dashboard de Plataforma';
                if (ADMIN_SUBTITLE) ADMIN_SUBTITLE.classList.remove('hidden');
                if (STUDENT_SEARCH_WRAP) STUDENT_SEARCH_WRAP.style.display = 'none';
                if (btnOpen) btnOpen.style.display = 'none';
                if (ADMIN_DASHBOARD) ADMIN_DASHBOARD.classList.remove('hidden');
                if (ACADEMIC_DASHBOARD) ACADEMIC_DASHBOARD.classList.add('hidden');

                const res = await fetch('/api/admin/metrics/users');
                const data = await res.json();
                if (!res.ok) throw new Error(data.error || 'Error cargando métricas de plataforma');
                actualizarDashboardAdmin(data);
            } catch (error) {
                console.error('Error en dashboard admin:', error);
                document.getElementById('adminPlatformHealth').textContent = 'No se pudieron cargar las métricas de plataforma.';
            }
        }

        // Función para actualizar toda la UI del dashboard (fusionada con métricas del segundo código)
        function actualizarDashboard(data) {
            // Textos principales
            WELCOME_TITLE.textContent = `Estudiante: ${data.alumno.NombreCompleto}`;
            PLAN_DETAILS.innerHTML = `<b>${data.alumno.NombreCarrera}</b><br/>${data.alumno.NombrePlan} (${data.alumno.AnioPlan || ''})`;

            // Progreso circular
            const uvsAprobadas = data.progreso.uvsAprobadas || 0;
            const uvsPlan = data.progreso.totalUvsPlan || 1;
            const porcentaje = data.progreso.porcentaje || 0;

            const perimetro = 314;
            const offset = perimetro - (porcentaje / 100) * perimetro;

            CIRCLE.style.strokeDashoffset = offset;
            PERC_TEXT.textContent = `${porcentaje}%`;
            TOTAL_UVS.textContent = uvsPlan;
            APRO_UVS.textContent = uvsAprobadas;

            // Rendimiento académico
            const aprobadas = data.rendimiento.aprobadas || 0;
            const enCurso = data.rendimiento.enCurso || 0;
            
            document.getElementById('indiceAcademico').textContent = data.alumno.IndiceAcademico || '0.00';
            document.getElementById('statAprobadas').textContent = aprobadas;
            document.getElementById('statReprobadas').textContent = data.rendimiento.reprobadas || 0;
            document.getElementById('statEnCurso').textContent = enCurso;
            document.getElementById('promedioGeneral').textContent = data.rendimiento.promedioGeneral || '0.00';

            // NUEVAS MÉTRICAS (del segundo código)
            const totalMaterias = data.planEstudio.totalMaterias || 0;
            const materiasRestantes = totalMaterias - aprobadas;
            
            totalMateriasRestantes.textContent = materiasRestantes;
            totalMateriasPlan.textContent = totalMaterias;
            statEnCursoMaterias.textContent = enCurso;
            statAprobadasTotal.textContent = aprobadas;

            // Materias en curso (lista detallada)
            const materiasContainer = document.getElementById('materiasEnCursoContainer');
            let totalUvsCurso = 0;
            
            if (data.materiasEnCurso && data.materiasEnCurso.length > 0) {
                let html = '';
                data.materiasEnCurso.forEach(materia => {
                    totalUvsCurso += materia.UVS || 0;
                    html += `
                        <div class="flex justify-between items-center text-xs py-1">
                            <span class="font-medium truncate max-w-[150px]">${materia.CodigoMateria} - ${materia.NombreMateria}</span>
                            <span class="bg-blue-100 text-blue-800 px-2 py-0.5 rounded-full text-[10px] font-semibold">${materia.UVS || 0} UV</span>
                        </div>
                    `;
                });
                materiasContainer.innerHTML = html;
            } else {
                materiasContainer.innerHTML = '<p class="text-xs text-slate-400 text-center py-2">No hay materias en curso</p>';
            }
            
            totalUvsEnCurso.textContent = totalUvsCurso;

            // Próximas materias sugeridas
            const proximasContainer = document.getElementById('proximasMateriasContainer');
            if (data.proximasMaterias && data.proximasMaterias.length > 0) {
                let html = '';
                data.proximasMaterias.forEach(materia => {
                    html += `
                        <div class="flex justify-between items-center text-xs">
                            <span class="font-medium truncate max-w-[150px]">${materia.CodigoMateria}</span>
                            <span class="text-slate-500">${materia.UVS || 0} UV</span>
                        </div>
                        <p class="text-[10px] text-slate-400 -mt-2 mb-2">${materia.NombreMateria}</p>
                    `;
                });
                proximasContainer.innerHTML = html;
            } else {
                proximasContainer.innerHTML = '<p class="text-xs text-slate-400 text-center py-2">¡Has completado todas las materias!</p>';
            }

            // Guardar historial para paginación y resetear página
            currentHistorialData = data.historialCompleto || [];
            currentPage = 1;
            // Resetear el toggle a paginación por defecto al cargar nuevo alumno
            if (showAllToggle && showAllToggle.checked) {
                showAllToggle.checked = false;
                showAllMode = false;
            }
            renderHistorialWithPagination();
        }

        // Función para obtener la cuenta a la que se importarán los datos
        function getTargetAccount() {
            if (userFromStorage.rol === 1 || userFromStorage.rol === 2) {
                const manualAccount = document.getElementById('manualAccountInput')?.value.trim();
                if (manualAccount && !textSection.classList.contains('hidden')) {
                    return manualAccount;
                }

                const inputValue = ALUMNO_INPUT ? ALUMNO_INPUT.value : '';
                if (inputValue) {
                    return inputValue.split(' - ')[0].trim();
                }

                return 'ADMIN_IMPORT';
            }
            return userAccount;
        }

        // --- RESTRICCIONES DE IMPORTACIÓN POR ROL ---
        const manualAccountSection = document.getElementById('manualAccountSection');
        const manualAccountInput = document.getElementById('manualAccountInput');
        const manualAccountHelp = document.getElementById('manualAccountHelp');

        if (manualAccountSection) manualAccountSection.classList.remove('hidden');

        if (userFromStorage.rol === 3) {
            if (tabFile) tabFile.style.display = 'none';
            if (tabPaste) tabPaste.click();

            if (manualAccountInput) {
                manualAccountInput.value = userAccount;
                manualAccountInput.readOnly = true;
                manualAccountInput.classList.add('bg-gray-100', 'text-gray-500', 'cursor-not-allowed');
            }
            if (manualAccountHelp) {
                manualAccountHelp.innerHTML = '<i class="fas fa-info-circle mr-1"></i> Los registros se importarán obligatoriamente con tu número de cuenta actual.';
            }
        } else {
            if (manualAccountInput) {
                manualAccountInput.readOnly = false;
                manualAccountInput.classList.remove('bg-gray-100', 'text-gray-500', 'cursor-not-allowed');
            }
        }

        // Cargar datos del alumno actual automáticamente
        async function cargarDashboardAlumnoActual() {
            if (!userAccount) {
                console.error('No hay número de cuenta de usuario');
                WELCOME_TITLE.textContent = 'Estudiante: No Seleccionado';
                return;
            }

            try {
                WELCOME_TITLE.textContent = 'Estudiante: Cargando...';

                const res = await fetch('/api/alumnos/' + userAccount + '/dashboard');
                const data = await res.json();

                if (!res.ok) throw new Error(data.error);

                actualizarDashboard(data);

            } catch (err) {
                console.error('Error al cargar dashboard:', err);
                WELCOME_TITLE.textContent = 'Estudiante: Error al cargar datos';
                TABLE_BODY.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-red-400 italic">Error al cargar el historial</td></tr>';
            }
        }

        // Cargar Lista de Alumnos y combobox de búsqueda
        async function fetchAlumnos() {
            try {
                const res = await fetch('/api/alumnos');
                const alumnos = await res.json();

                if (alumnos.length === 0) return;

                window.alumnosData = alumnos;

                if (userFromStorage.rol !== 3 && typeof window.initStudentSearchCombobox === 'function' && ALUMNO_INPUT) {
                    window.initStudentSearchCombobox({
                        input: ALUMNO_INPUT,
                        getAlumnos: () => window.alumnosData,
                        onSelect: async (alumno) => {
                            const cuenta = alumno.NumeroCuenta;
                            try {
                                WELCOME_TITLE.textContent = 'Cargando...';
                                CIRCLE.style.strokeDashoffset = 314;
                                const resDash = await fetch('/api/alumnos/' + cuenta + '/dashboard');
                                const data = await resDash.json();
                                if (!resDash.ok) throw new Error(data.error);
                                actualizarDashboard(data);
                            } catch (err) {
                                console.error(err);
                                WELCOME_TITLE.textContent = 'Error al cargar datos';
                            }
                        },
                        onClear: () => cargarDashboardAlumnoActual(),
                    });
                }
            } catch (err) {
                console.error('Error al cargar selector:', err);
            }
        }

        // Lógica del Modal
        btnOpen.onclick = () => {
            const target = getTargetAccount();
            if (userAccountDisplay) {
                userAccountDisplay.textContent = target && target !== 'ADMIN_IMPORT' ? target : (userAccount || 'N/A');
            }
            modal.classList.remove('hidden');
            showFileTab();
            previewSection.classList.add('hidden');
            pasteArea.value = '';
        };

        btnClose.onclick = () => {
            modal.classList.add('hidden');
            statusMsg.classList.add('hidden');
            fileInfo.classList.add('hidden');
            form.reset();
            previewSection.classList.add('hidden');
            currentPreviewData = null;
        };

        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                statusMsg.classList.add('hidden');
                fileInfo.classList.add('hidden');
                form.reset();
                previewSection.classList.add('hidden');
                currentPreviewData = null;
            }
        });

        function showFileTab() {
            tabFile.classList.add('text-[#B20000]', 'border-b-2', 'border-[#B20000]');
            tabFile.classList.remove('text-gray-500');
            tabPaste.classList.remove('text-[#B20000]', 'border-b-2', 'border-[#B20000]');
            tabPaste.classList.add('text-gray-500');
            fileSection.classList.remove('hidden');
            textSection.classList.add('hidden');
            previewSection.classList.add('hidden');
        }

        function showPasteTab() {
            tabPaste.classList.add('text-[#B20000]', 'border-b-2', 'border-[#B20000]');
            tabPaste.classList.remove('text-gray-500');
            tabFile.classList.remove('text-[#B20000]', 'border-b-2', 'border-[#B20000]');
            tabFile.classList.add('text-gray-500');
            textSection.classList.remove('hidden');
            fileSection.classList.add('hidden');
            previewSection.classList.add('hidden');
        }

        tabFile.addEventListener('click', showFileTab);
        tabPaste.addEventListener('click', showPasteTab);

        // Drag & Drop archivo
        dropZone.onclick = () => fileInput.click();

        fileInput.onchange = (e) => {
            if (e.target.files.length) {
                fileInfo.classList.remove('hidden');
                fileName.textContent = e.target.files[0].name;
            }
        };

        // Envío de Formulario (archivo)
        form.onsubmit = async (e) => {
            e.preventDefault();
            const file = fileInput.files[0];
            if (!file) {
                showStatus('Por favor selecciona un archivo', 'text-red-600');
                return;
            }

            const targetAccount = getTargetAccount();
            if (!targetAccount) {
                showStatus('Error: No se pudo determinar la cuenta de destino', 'text-red-600');
                return;
            }

            const formData = new FormData();
            formData.append('archivo', file);
            formData.append('numeroCuenta', targetAccount);

            try {
                btnSubmit.disabled = true;
                btnSubmit.textContent = 'Procesando...';
                showStatus('Subiendo y analizando archivo...', 'text-blue-600');

                const response = await fetch('/api/ingest/upload', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (response.ok) {
                    showStatus(`¡Éxito! Se procesaron ${data.recordsProcessed} registros. (${data.inserts} nuevos, ${data.updates} actualizados)`, 'text-green-600');
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showStatus(data.error || 'Error al procesar el archivo', 'text-red-600');
                }
            } catch (error) {
                showStatus('Error de conexión con el servidor', 'text-red-600');
            } finally {
                btnSubmit.disabled = false;
                btnSubmit.textContent = 'Comenzar Procesamiento';
            }
        };

        // Vista previa de texto
        btnPreviewText.addEventListener('click', async () => {
            const text = pasteArea.value.trim();
            if (!text) {
                showStatus('Por favor pega algún contenido', 'text-red-600');
                return;
            }

            const targetAccount = getTargetAccount();
            if (!targetAccount) {
                showStatus('Error: No se pudo determinar la cuenta de destino', 'text-red-600');
                return;
            }

            try {
                btnPreviewText.disabled = true;
                btnPreviewText.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Procesando...';
                showStatus('Procesando texto...', 'text-[#B20000]');

                const response = await fetch('/api/ingest/preview-text', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Error al procesar el texto');
                }

                currentPreviewData = data.allData;
                renderPreview(data.preview);
                previewSection.classList.remove('hidden');
                showStatus(`Se encontraron ${data.total} registros. Revisa la vista previa.`, 'text-green-600');

            } catch (error) {
                showStatus(error.message, 'text-red-600');
            } finally {
                btnPreviewText.disabled = false;
                btnPreviewText.innerHTML = '<i class="fas fa-eye mr-2"></i> Vista Previa';
            }
        });

        function renderPreview(data) {
            if (!data || data.length === 0) {
                previewTableBody.innerHTML = '<tr><td colspan="5" class="px-4 py-4 text-center text-slate-400">No se encontraron datos</td></tr>';
                previewCount.textContent = '(0 registros)';
                return;
            }

            let html = '';
            data.forEach((row, index) => {
                const estadoClass = row.estado === 'APB' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800';
                html += `
                    <tr class="${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}">
                        <td class="px-4 py-2 whitespace-nowrap font-mono text-xs">${escapeHtml(row.codigo_materia || 'N/A')}</td>
                        <td class="px-4 py-2 whitespace-nowrap max-w-xs truncate text-xs">${escapeHtml(row.nombre_materia || 'N/A')}</td>
                        <td class="px-4 py-2 whitespace-nowrap text-xs">${escapeHtml(row.nota || 'N/A')}</td>
                        <td class="px-4 py-2 whitespace-nowrap text-xs">
                            <span class="${estadoClass} px-2 py-1 rounded-full text-xs font-semibold">
                                ${escapeHtml(row.estado || 'N/A')}
                            </span>
                        </td>
                        <td class="px-4 py-2 whitespace-nowrap text-xs">${escapeHtml(row.uvs || 'N/A')}</td>
                    </tr>
                `;
            });

            previewTableBody.innerHTML = html;
            previewCount.textContent = `(${data.length} registros mostrados de ${currentPreviewData ? currentPreviewData.length : 0})`;
        }

        btnCancelPreview.addEventListener('click', () => {
            previewSection.classList.add('hidden');
            currentPreviewData = null;
            showPasteTab();
        });

        btnAcceptPreview.addEventListener('click', async () => {
            if (!currentPreviewData || currentPreviewData.length === 0) {
                showStatus('No hay datos para importar', 'text-red-600');
                return;
            }

            const targetAccount = getTargetAccount();
            if (!targetAccount || targetAccount === 'ADMIN_IMPORT') {
                showStatus('Error: Debes seleccionar un estudiante antes de confirmar la importación.', 'text-red-600');
                return;
            }

            try {
                btnAcceptPreview.disabled = true;
                btnAcceptPreview.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Importando...';

                const bypassPlan = (userFromStorage.rol === 1 || userFromStorage.rol === 2);

                const response = await fetch('/api/ingest/import', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        cuenta: targetAccount,
                        data: currentPreviewData,
                        bypassPlanValidation: bypassPlan
                    })
                });

                const result = await response.json();

                if (response.ok) {
                    showStatus(`¡Éxito! Se importaron ${result.recordsProcessed} registros. (${result.inserts} nuevos, ${result.updates} actualizados)`, 'text-green-600');
                    setTimeout(() => {
                        modal.classList.add('hidden');
                        location.reload();
                    }, 2000);
                } else {
                    throw new Error(result.error || 'Error al importar');
                }

            } catch (error) {
                showStatus(error.message, 'text-red-600');
                btnAcceptPreview.disabled = false;
                btnAcceptPreview.innerHTML = 'Aceptar e Importar';
            }
        });

        function showStatus(text, colorClass) {
            statusMsg.textContent = text;
            statusMsg.className = `mt-4 text-center text-sm font-semibold ${colorClass}`;
            statusMsg.classList.remove('hidden');
        }

        function escapeHtml(value) {
            return (value || '')
                .toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        // Eventos de paginación
        if (prevPageBtn) {
            prevPageBtn.addEventListener('click', () => {
                if (currentPage > 1 && !showAllMode) {
                    currentPage--;
                    renderHistorialWithPagination();
                }
            });
        }

        if (nextPageBtn) {
            nextPageBtn.addEventListener('click', () => {
                const totalPages = Math.ceil(currentHistorialData.length / itemsPerPage);
                if (currentPage < totalPages && !showAllMode) {
                    currentPage++;
                    renderHistorialWithPagination();
                }
            });
        }

        // Inicialización
        if (IS_ADMIN) {
            cargarDashboardAdmin();
        } else {
            fetchAlumnos();
            cargarDashboardAlumnoActual();
        }

        // Configuración de Drag & Drop para el DropZone
        const externalDropZone = document.getElementById('dropZone');
        const hiddenExcelInput = document.getElementById('excelFile');

        if (externalDropZone && hiddenExcelInput) {
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                externalDropZone.addEventListener(eventName, preventDefaults, false);
            });

            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover'].forEach(eventName => {
                externalDropZone.addEventListener(eventName, () => {
                    externalDropZone.classList.add('border-[#B20000]', 'bg-red-50');
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                externalDropZone.addEventListener(eventName, () => {
                    externalDropZone.classList.remove('border-[#B20000]', 'bg-red-50');
                }, false);
            });

            externalDropZone.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;

                if (files && files.length > 0) {
                    hiddenExcelInput.files = files;
                    const event = new Event('change');
                    hiddenExcelInput.dispatchEvent(event);
                }
            }, false);
        }
    </script>
</body>

</html>