<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración | CEUTEC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/auth-guard.js"></script>
    <script src="/js/profile-widget.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
            overflow-x: hidden;
        }

        /* Sidebar fijo */
        .sidebar-fixed {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            overflow-y: auto;
            z-index: 50;
        }

        .main-content {
            margin-left: 256px;
            min-height: 100vh;
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }
        }

        @media print {
            .sidebar-fixed {
                display: none;
            }
            .main-content {
                margin-left: 0;
            }
            .no-print {
                display: none;
            }
        }

        /* Estilos adicionales para mejorar la experiencia */
        .table-row-hover:hover {
            background-color: #fef2f2;
            transition: background-color 0.2s ease;
        }

        .status-badge {
            transition: all 0.2s ease;
        }

        .status-badge:hover {
            transform: scale(1.05);
        }

        .action-button {
            transition: all 0.2s ease;
        }

        .action-button:hover {
            transform: translateY(-1px);
        }
    </style>
</head>

<body class="flex min-h-screen overflow-x-hidden">
    <%- include('partials/sidebar', { active: 'administracion', noPrint: false, extraAsideClasses: 'sidebar-fixed' }) %>

    <main class="flex-1 p-8 overflow-y-auto main-content">
        <header class="flex justify-between items-center mb-8 no-print">
            <div>
                <h1 class="text-2xl font-bold text-slate-800">Administración</h1>
                <p class="text-sm text-slate-500 mt-1">Gestiona usuarios, roles y estados de acceso del sistema.</p>
            </div>
            <div class="flex items-center gap-3">
                <button id="btnRefreshAdminData"
                    class="bg-white border border-gray-300 text-slate-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition flex items-center action-button">
                    <i class="fas fa-rotate mr-2"></i> Recargar
                </button>
                <%- include('partials/profile-widget') %>
            </div>
        </header>

        <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-5 mb-6 no-print">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Buscar usuario</label>
                    <input id="adminSearchInput" type="text" placeholder="Nombre, correo o cuenta"
                        class="w-full border border-gray-300 rounded-lg p-2.5 text-sm focus:ring-[#B20000] focus:border-[#B20000] transition">
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Filtrar por rol</label>
                    <select id="adminRoleFilter"
                        class="w-full border border-gray-300 rounded-lg p-2.5 text-sm focus:ring-[#B20000] focus:border-[#B20000] transition">
                        <option value="">Todos</option>
                        <option value="1">Administrador</option>
                        <option value="2">Jefe de Carrera</option>
                        <option value="3">Estudiante</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Filtrar por estado</label>
                    <select id="adminStatusFilter"
                        class="w-full border border-gray-300 rounded-lg p-2.5 text-sm focus:ring-[#B20000] focus:border-[#B20000] transition">
                        <option value="">Todos</option>
                        <option value="active">Activos</option>
                        <option value="inactive">Inactivos</option>
                    </select>
                </div>
            </div>
            <p id="adminFeedback" class="hidden mt-3 text-sm rounded-lg px-3 py-2"></p>
        </section>

        <section class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden mb-8">
            <div class="px-5 py-4 border-b border-gray-200">
                <h2 class="font-semibold text-slate-800">Usuarios</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-slate-50">
                        <tr class="text-left text-xs uppercase text-slate-500">
                            <th class="px-4 py-3">Usuario</th>
                            <th class="px-4 py-3">Cuenta</th>
                            <th class="px-4 py-3">Rol</th>
                            <th class="px-4 py-3">Estado</th>
                            <th class="px-4 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="adminUsersTableBody" class="divide-y divide-gray-100 text-sm text-slate-700">
                        <tr>
                            <td colspan="5" class="px-4 py-6 text-center text-slate-400 italic">Cargando usuarios...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-200 flex justify-between items-center">
                <h2 class="font-semibold text-slate-800">Auditoría de roles y estados</h2>
                <span class="text-xs text-slate-400">Últimos cambios administrativos</span>
            </div>
            <div class="overflow-x-auto overflow-y-auto max-h-72">
                <table class="min-w-full">
                    <thead class="bg-slate-50 sticky top-0 z-10">
                        <tr class="text-left text-xs uppercase text-slate-500">
                            <th class="px-4 py-3">Fecha</th>
                            <th class="px-4 py-3">Admin</th>
                            <th class="px-4 py-3">Usuario objetivo</th>
                            <th class="px-4 py-3">Cambio</th>
                            <th class="px-4 py-3">IP</th>
                        </tr>
                    </thead>
                    <tbody id="adminAuditTableBody" class="divide-y divide-gray-100 text-sm text-slate-700">
                        <tr>
                            <td colspan="5" class="px-4 py-6 text-center text-slate-400 italic">Cargando auditoría...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="/js/administracion.js"></script>
</body>

</html>