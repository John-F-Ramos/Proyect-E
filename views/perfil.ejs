<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil | CEUTEC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/auth-guard.js"></script>
    <script src="/js/profile-widget.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
    </style>
</head>

<body class="flex min-h-screen">
    <%- include('partials/sidebar', { active: 'perfil', noPrint: false, extraAsideClasses: '' }) %>

    <main class="flex-1 p-8 overflow-y-auto">
        <header class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold text-slate-800">Mi Perfil</h1>
            <%- include('partials/profile-widget') %>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Cuenta Info -->
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center mb-6">
                    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-[#B20000] mr-4">
                        <i class="fas fa-id-card text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Detalles de la Cuenta</h3>
                        <p class="text-sm text-slate-500">Información básica de tu perfil</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <div id="cuentaContainer">
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">ID
                            Usuario / Cuenta</label>
                        <p class="text-slate-800 font-medium" id="profId">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Nombre
                            Completo</label>
                        <p class="text-slate-800 font-medium" id="profNombre">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Correo
                            Institucional</label>
                        <p class="text-slate-800 font-medium" id="profCorreo">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Fecha de
                            Creación</label>
                        <p class="text-slate-800 font-medium" id="profFecha">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Rol de
                            Usuario</label>
                        <span
                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-[#B20000]"
                            id="profRol">
                            Cargando...
                        </span>
                    </div>
                </div>
            </div>

            <!-- Seguridad -->
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center mb-6">
                    <div
                        class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center text-slate-600 mr-4">
                        <i class="fas fa-shield-alt text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Seguridad</h3>
                        <p class="text-sm text-slate-500">Estado de tu cuenta</p>
                    </div>
                </div>
                <div class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                    <div class="flex items-center text-green-600">
                        <i class="fas fa-check-circle mr-2"></i>
                        <span class="text-sm font-medium">Cuenta Activa</span>
                    </div>
                    <p class="text-xs text-slate-500 mt-2">Tu cuenta cumple con todos los requisitos de seguridad
                        vigentes.</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function completarDatosDesdeServidor(user) {
            if (!user || !user.id) return user;
            if (user.correoInstitucional || user.correo) return user;

            try {
                const res = await fetch(`/api/auth/user/${user.id}`);
                if (!res.ok) return user;
                const data = await res.json();
                const merged = { ...user, ...data };
                localStorage.setItem('user', JSON.stringify(merged));
                return merged;
            } catch (e) {
                return user;
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            const userStr = localStorage.getItem('user');
            if (userStr) {
                let user = JSON.parse(userStr);
                user = await completarDatosDesdeServidor(user);
                if (user.rol === 1 || user.rol === 2) {
                    const cuentaContainer = document.getElementById('cuentaContainer');
                    if (cuentaContainer) cuentaContainer.classList.add('hidden');
                } else {
                    document.getElementById('profId').textContent = user.idUsuario || user.numeroCuenta || 'N/A';
                }
                document.getElementById('profNombre').textContent = user.nombre || 'N/A';
                document.getElementById('profCorreo').textContent = user.correo || user.correoInstitucional || 'N/A';

                // Formatear fecha si existe
                if (user.fechaCreacion) {
                    const fecha = new Date(user.fechaCreacion);
                    document.getElementById('profFecha').textContent = fecha.toLocaleDateString('es-ES', {
                        year: 'numeric', month: 'long', day: 'numeric'
                    });
                } else {
                    document.getElementById('profFecha').textContent = 'No disponible';
                }

                document.getElementById('profRol').textContent = user.rolNombre || (user.rol === 1 ? 'Administrador' : user.rol === 2 ? 'Jefe de Carrera' : 'Estudiante');
            } else {
                window.location.href = '/';
            }
        });
    </script>
</body>

</html>