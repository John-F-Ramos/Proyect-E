<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Perfil | CEUTEC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/auth-guard.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
    </style>
</head>

<body class="flex min-h-screen">
    <aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col">
        <div class="p-6">
            <img src="/assets/images/logo-ceutec.png" alt="CEUTEC" class="h-10 mb-8">
            <nav class="space-y-1">
                <a href="/dashboard"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition group">
                    <i class="fas fa-home mr-3 text-gray-400 group-hover:text-[#B20000]"></i> Dashboard
                </a>
                <a href="/equivalencias"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-exchange-alt mr-3 text-gray-400"></i> Equivalencias
                </a>
                <a href="/plan-estudio"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-book mr-3 text-gray-400"></i> Catálogos Académicos
                </a>
                <a href="/reportes"
                    class="flex items-center px-4 py-3 text-gray-600 hover:bg-slate-50 rounded-lg transition">
                    <i class="fas fa-file-alt mr-3 text-gray-400"></i> Reportes
                </a>
                <a href="/perfil"
                    class="flex items-center px-4 py-3 bg-slate-100 text-slate-900 font-semibold rounded-lg">
                    <i class="fas fa-user mr-3 text-[#B20000]"></i> Mi Perfil
                </a>
            </nav>
        </div>
        <div class="mt-auto p-6 border-t border-gray-200">
            <button onclick="localStorage.removeItem('user'); window.location.href='/';"
                class="flex items-center w-full px-4 py-3 text-red-600 hover:bg-red-50 rounded-lg transition font-medium">
                <i class="fas fa-sign-out-alt mr-3"></i> Cerrar Sesión
            </button>
        </div>
    </aside>

    <main class="flex-1 p-8 overflow-y-auto">
        <header class="flex justify-between items-center mb-8">
            <h1 class="text-2xl font-bold text-slate-800">Mi Perfil</h1>
            <div class="relative inline-block text-left" id="profileWidget">
                <button type="button"
                    class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center text-[#B20000] hover:bg-red-200 transition focus:outline-none"
                    id="profileDropdownBtn">
                    <i class="fas fa-user"></i>
                </button>
                <div id="profileDropdown"
                    class="hidden absolute right-0 mt-2 w-56 origin-top-right rounded-xl bg-white shadow-2xl ring-1 ring-black ring-opacity-5 focus:outline-none z-[100] border border-gray-100">
                    <div class="p-4 border-b border-gray-100">
                        <p class="text-sm font-bold text-slate-800 truncate" id="dropdownUserName">Nombre Usuario</p>
                        <p class="text-xs text-slate-500 mt-0.5" id="dropdownUserRole">Rol Usuario</p>
                    </div>
                    <div class="py-2">
                        <a href="/perfil"
                            class="flex items-center px-4 py-2 text-sm text-slate-700 hover:bg-slate-50 transition group">
                            <i class="fas fa-user-circle mr-3 text-slate-400 group-hover:text-[#B20000]"></i> Mi Perfil
                        </a>
                        <button onclick="localStorage.removeItem('user'); window.location.href='/';"
                            class="flex items-center w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition group">
                            <i class="fas fa-sign-out-alt mr-3 text-red-400 group-hover:text-red-600"></i> Cerrar Sesión
                        </button>
                    </div>
                </div>
            </div>
        </header>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Cuenta Info -->
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center mb-6">
                    <div class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center text-[#B20000] mr-4">
                        <i class="fas fa-id-card text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Detalles de la Cuenta</h3>
                        <p class="text-sm text-slate-500">Información básica de tu perfil</p>
                    </div>
                </div>

                <div class="space-y-4">
                    <div id="cuentaContainer">
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">ID
                            Usuario / Cuenta</label>
                        <p class="text-slate-800 font-medium" id="profId">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Nombre
                            Completo</label>
                        <p class="text-slate-800 font-medium" id="profNombre">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Correo
                            Institucional</label>
                        <p class="text-slate-800 font-medium" id="profCorreo">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Fecha de
                            Creación</label>
                        <p class="text-slate-800 font-medium" id="profFecha">Cargando...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">Rol de
                            Usuario</label>
                        <span
                            class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-[#B20000]"
                            id="profRol">
                            Cargando...
                        </span>
                    </div>
                </div>
            </div>

            <!-- Seguridad -->
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
                <div class="flex items-center mb-6">
                    <div
                        class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center text-slate-600 mr-4">
                        <i class="fas fa-shield-alt text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-lg font-bold text-slate-800">Seguridad</h3>
                        <p class="text-sm text-slate-500">Estado de tu cuenta</p>
                    </div>
                </div>
                <div class="p-4 bg-slate-50 rounded-xl border border-slate-200">
                    <div class="flex items-center text-green-600">
                        <i class="fas fa-check-circle mr-2"></i>
                        <span class="text-sm font-medium">Cuenta Activa</span>
                    </div>
                    <p class="text-xs text-slate-500 mt-2">Tu cuenta cumple con todos los requisitos de seguridad
                        vigentes.</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        function nombreRol(rol) {
            if (rol === 1) return 'Administrador';
            if (rol === 2) return 'Jefe de Carrera';
            return 'Estudiante';
        }

        function inicializarProfileWidget(user) {
            const profileDropdownBtn = document.getElementById('profileDropdownBtn');
            const profileDropdown = document.getElementById('profileDropdown');
            const dropdownUserName = document.getElementById('dropdownUserName');
            const dropdownUserRole = document.getElementById('dropdownUserRole');
            if (!profileDropdownBtn || !profileDropdown) return;

            if (dropdownUserName) dropdownUserName.textContent = user?.nombre || 'Usuario';
            if (dropdownUserRole) dropdownUserRole.textContent = user?.rolNombre || nombreRol(user?.rol);

            profileDropdownBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
            });

            document.addEventListener('click', (e) => {
                if (!profileDropdown.classList.contains('hidden') && !profileDropdown.contains(e.target) && e.target !== profileDropdownBtn) {
                    profileDropdown.classList.add('hidden');
                }
            });
        }

        async function completarDatosDesdeServidor(user) {
            if (!user || !user.id) return user;
            if (user.correoInstitucional || user.correo) return user;

            try {
                const res = await fetch(`/api/auth/user/${user.id}`);
                if (!res.ok) return user;
                const data = await res.json();
                const merged = { ...user, ...data };
                localStorage.setItem('user', JSON.stringify(merged));
                return merged;
            } catch (e) {
                return user;
            }
        }

        document.addEventListener('DOMContentLoaded', async () => {
            const userStr = localStorage.getItem('user');
            if (userStr) {
                let user = JSON.parse(userStr);
                user = await completarDatosDesdeServidor(user);
                inicializarProfileWidget(user);
                if (user.rol === 1 || user.rol === 2) {
                    const cuentaContainer = document.getElementById('cuentaContainer');
                    if (cuentaContainer) cuentaContainer.classList.add('hidden');
                } else {
                    document.getElementById('profId').textContent = user.idUsuario || user.numeroCuenta || 'N/A';
                }
                document.getElementById('profNombre').textContent = user.nombre || 'N/A';
                document.getElementById('profCorreo').textContent = user.correo || user.correoInstitucional || 'N/A';

                // Formatear fecha si existe
                if (user.fechaCreacion) {
                    const fecha = new Date(user.fechaCreacion);
                    document.getElementById('profFecha').textContent = fecha.toLocaleDateString('es-ES', {
                        year: 'numeric', month: 'long', day: 'numeric'
                    });
                } else {
                    document.getElementById('profFecha').textContent = 'No disponible';
                }

                document.getElementById('profRol').textContent = user.rolNombre || (user.rol === 1 ? 'Administrador' : user.rol === 2 ? 'Jefe de Carrera' : 'Estudiante');
            } else {
                window.location.href = '/';
            }
        });
    </script>
</body>

</html>