<aside class="w-64 bg-white border-r border-gray-200 hidden md:flex flex-col <%= noPrint ? 'no-print' : '' %> <%= extraAsideClasses || '' %>">
    <div class="p-6">
        <img src="/assets/images/logo-ceutec.png" alt="CEUTEC" class="h-10 mb-8">
        <nav class="space-y-1">
            <a href="/dashboard"
                class="flex items-center px-4 py-3 rounded-lg transition group <%= active === 'dashboard' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-home mr-3 <%= active === 'dashboard' ? 'text-[#B20000]' : 'text-gray-400 group-hover:text-[#B20000]' %>"></i> Dashboard
            </a>
            <a href="/equivalencias"
                data-no-admin="true"
                class="flex items-center px-4 py-3 rounded-lg transition <%= active === 'equivalencias' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-exchange-alt mr-3 <%= active === 'equivalencias' ? 'text-[#B20000]' : 'text-gray-400' %>"></i> Equivalencias
            </a>
            <a href="/plan-estudio"
                class="flex items-center px-4 py-3 rounded-lg transition <%= active === 'plan-estudio' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-book mr-3 <%= active === 'plan-estudio' ? 'text-[#B20000]' : 'text-gray-400' %>"></i> Catálogos Académicos
            </a>
            <a href="/reportes"
                class="flex items-center px-4 py-3 rounded-lg transition <%= active === 'reportes' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-file-alt mr-3 <%= active === 'reportes' ? 'text-[#B20000]' : 'text-gray-400' %>"></i> Reportes
            </a>
            <a href="/administracion"
                data-admin-only="true"
                class="hidden flex items-center px-4 py-3 rounded-lg transition <%= active === 'administracion' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-user-shield mr-3 <%= active === 'administracion' ? 'text-[#B20000]' : 'text-gray-400' %>"></i> Administración
            </a>
            <a href="/perfil"
                class="flex items-center px-4 py-3 rounded-lg transition <%= active === 'perfil' ? 'bg-slate-100 text-slate-900 font-semibold' : 'text-gray-600 hover:bg-slate-50' %>">
                <i class="fas fa-user mr-3 <%= active === 'perfil' ? 'text-[#B20000]' : 'text-gray-400' %>"></i> Mi Perfil
            </a>
        </nav>
    </div>
    <div class="mt-auto p-6 border-t border-gray-200">
        <button onclick="localStorage.removeItem('user'); window.location.href='/';"
            class="flex items-center w-full px-4 py-3 text-red-600 hover:bg-red-50 rounded-lg transition font-medium">
            <i class="fas fa-sign-out-alt mr-3"></i> Cerrar Sesión
        </button>
    </div>
</aside>
